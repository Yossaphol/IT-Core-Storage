<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Receiving</title>
    <link rel="stylesheet" href="/css/receiving_issue_adjust.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="/css/font.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/flowbite@2.4.1/dist/flowbite.min.js"></script>
    <style>
        .datepicker {
            z-index: 1050 !important;
        }
    </style>
</head>
<body class="bg-[#0E1324]"> <div class="relative z-40">
    <div class="fixed top-[20px] right-[50px] pointer-events-none z-0 overflow-hidden select-none">
        <i class="fa-solid fa-list-check text-[500px] text-white/[0.03]"></i>
    </div>
        <%- include('../partials/header_with_path', { path1 : "รับสินค้าเข้า", url_1 : "/receiving"}) %>
    </div>

    <div class="ml-[110px] pt-[120px] px-16 relative z-10 text-white">
        <div class="flex justify-between items-center mb-10">
            <h1 class="text-3xl font-semibold">
                สินค้ารอเข้าคลัง
                <span class="text-base text-gray-400 font-normal">
                    (กรณีคลังเต็มหรือไม่พร้อม)
                </span>
            </h1>

            <button data-modal-target="add-product-modal" data-modal-toggle="add-product-modal" class="bg-yellow-500 hover:bg-yellow-400 font-medium px-6 py-3 rounded-xl flex items-center gap-2 transition text-white">
                <i class="fa-solid fa-plus"></i>
                เพิ่มสินค้า
            </button>
        </div>

        <div class="border border-dashed border-blue-500/40 rounded-2xl p-8 mb-16 overflow-x-auto [&::-webkit-scrollbar]:h-1
        [&::-webkit-scrollbar-track]:bg-transparent
        [&::-webkit-scrollbar-thumb]:bg-[#5E5E5E]
        [&::-webkit-scrollbar-thumb]:rounded-full
        [&::-webkit-scrollbar-thumb:hover]:bg-gray-300">
            <div class="grid grid-flow-col auto-cols-max gap-10">
                <% pendingItems.forEach((item) => { %>
                <div class="relative w-[350px] h-[260px] rounded-2xl overflow-hidden">
                    <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('<%= item.prod_img %>');"></div>
                    <div class="absolute inset-0 bg-gradient-to-t from-[#0E1324]/90 via-[#0E1324]/60 to-transparent"></div>
                    <div class="relative z-10 p-6 text-white flex flex-col justify-end h-full">
                        <span class="bg-blue-800 px-3 py-1 text-xs rounded-md w-fit mb-4"><%= item.prod_type %></span>
                        <h3 class="text-3xl font-bold"><%= item.prod_name %></h3>
                        <p class="truncate"><%= item.description %></p>
                        <div class="flex justify-between mt-4 text-lg">
                            <div>
                                <p class="text-gray-300 text-sm">จำนวน</p>
                                <p class="text-2xl font-semibold"><%= item.amount %></p>
                            </div>
                            <div class="text-right">
                                <p class="text-gray-300 text-sm">วันที่รับเข้า</p>
                                <p class="text-xl font-semibold"><%= new Date(item.date_time).toLocaleDateString() %></p>
                            </div>
                        </div>
                    </div>
                </div>
                <% }); %>
            </div>
        </div>

        <h2 class="text-xl font-semibold mb-6">รายการล่าสุด</h2>
        <div class="bg-[#16233B] rounded-xl overflow-hidden mb-10">
            <table class="w-full text-left">
                <thead class="bg-[#203354] text-gray-300 text-sm">
                    <tr>
                        <th class="p-4">ID</th>
                        <th class="p-4">สินค้า</th>
                        <th class="p-4">ผู้ส่ง</th>
                        <th class="p-4">เจ้าหน้าที่รับสินค้า</th>
                        <th class="p-4">จำนวน</th>
                        <th class="p-4">วันที่-เวลา รับเข้า</th>
                    </tr>
                </thead>
                <tbody class="text-sm">
                    <% latestItems.forEach((item) => { %>
                    <tr class="border-t border-white/5 hover:bg-white/5">
                        <td class="p-4 text-gray-400">#<%= item.trans_id %></td>
                        <td class="p-4 flex items-center gap-3">
                            <img src="<%= item.prod_img %>" class="w-8 h-8 rounded-full object-cover">
                            <%= item.prod_name %>
                        </td>
                        <td class="p-4"><%= item.comp_name %></td>
                        <td class="p-4 text-blue-400">@<%= item.username %></td>
                        <td class="p-4 font-bold text-yellow-500"><%= item.amount %></td>
                        <td class="p-4 text-gray-400 text-xs">
                            <%= new Date(item.date_time).toLocaleString('th-TH') %>
                        </td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
    </div>

    <div id="add-product-modal" tabindex="-1" aria-hidden="true" class="fixed top-0 left-0 right-0 z-[100] hidden w-full p-4 overflow-x-hidden overflow-y-auto h-[calc(100%-1rem)] max-h-full flex items-center justify-center">
    <div class="relative w-full max-w-4xl max-h-full">
        <div class="relative bg-white rounded-2xl shadow-2xl">
            <button type="button" class="absolute top-4 right-4 text-gray-400 bg-transparent hover:bg-gray-200 hover:text-gray-900 rounded-lg text-sm w-8 h-8 ml-auto inline-flex justify-center items-center z-[110]" data-modal-hide="add-product-modal">
                <svg class="w-3 h-3" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 14">
                    <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"/>
                </svg>
                <span class="sr-only">Close modal</span>
            </button>

            <div class="relative py-16 px-16 z-16 bg-white rounded-2xl">
                <div class="header">
                    <p class="text-[#9E9E9E]">รับเข้า</p>
                    <h2 class="text-3xl font-semibold mb-6 text-[#1B3563]">รับสินค้าเข้า</h2>
                </div>
                <form id="receivingForm">
                    <div class="inputform">
                        <div class="flex flex-col w-full pt-3"> 
                            <span>
                                <label for="prod_name" class=" text-[16px] text-[#9E9E9E]">ชื่อสินค้า</label>
                                <input type="text" id="prod_name" name="prod_name" required class="bg-[#F5F5F5] border-b-2 border-[#1B3563] h-[40px] outline-0 p-3 w-[100%] text-[#1B3563]">
                            </span>
                            <span class="flex gap-4 w-[100%] mt-4">
                                <div class="flex flex-col w-[50%]">
                                    <label for="prod_code" class=" text-[16px] text-[#9E9E9E]">รหัสสินค้า</label>
                                    <input type="text" id="prod_code" name="prod_code" required class="bg-[#F5F5F5] border-b-2 border-[#1B3563] h-[40px] outline-0 p-3 w-[100%] text-[#1B3563]">
                                </div>
                                <div class="flex flex-col w-[50%]">
                                    <label for="brand" class=" text-[16px] text-[#9E9E9E]">แบรนด์</label>
                                    <input type="text" id="brand" name="brand" class="bg-[#F5F5F5] border-b-2 border-[#1B3563] h-[40px] outline-0 p-3 w-[100%] text-[#1B3563]">
                                </div>
                            </span>
                            <span class="flex gap-4 w-[100%] mt-4">
                                <div class="flex flex-col w-[50%]">
                                    <label for="prod_type" class=" text-[16px] text-[#9E9E9E]">ประเภท</label>
                                    <select name="prod_type" id="prod_type" class="bg-[#F5F5F5] border-b-2 border-[#1B3563] h-[40px] outline-0 px-2 w-[100%] text-[#1B3563]">
                                        <option value="CPU">CPU</option>
                                        <option value="Mainboard">Mainboard</option>
                                        <option value="GPU">GPU</option>
                                        <option value="RAM">RAM</option>
                                        <option value="HDD">Hard disk</option>
                                        <option value="SSD">Solid state drive</option>
                                        <option value="Case">Case</option>
                                        <option value="PowerSupply">Power Supply</option>
                                        <option value="CPUCooler">CPU Cooler</option>
                                        <option value="Monitor">Monitor</option>
                                        <option value="Other">Other</option>
                                    </select>
                                </div>
                                <div class="flex flex-col w-[50%]">
                                    <label for="amount" class=" text-[16px] text-[#9E9E9E]">จำนวน</label>
                                    <input type="number" id="amount" name="amount" required class="bg-[#F5F5F5] border-b-2 border-[#1B3563] h-[40px] outline-0 p-3 w-[100%] text-[#1B3563]">
                                </div>
                            </span>
                        </div>
                        
                        <div class="down mt-4">
                            <span class="flex gap-4 w-[100%]">
                                <div class="flex flex-col w-[50%]">
                                    <label for="emp_id" class="text-[16px] text-[#9E9E9E]">เจ้าหน้าที่รับเข้า</label>
                                    <select name="emp_id" id="emp_id" required class="bg-[#F5F5F5] border-b-2 border-[#1B3563] h-[40px] outline-0 px-2 w-[100%] text-[#1B3563]">
                                        <option value="" disabled selected>เลือกพนักงาน</option>
                                        <% employees.forEach((emp) => { %>
                                            <option value="<%= emp.emp_id %>" <%= emp.emp_id === user.emp_id ? 'selected' : '' %>>
                                                <%= emp.emp_firstname %> <%= emp.emp_lastname %>
                                            </option>
                                        <% }); %>
                                    </select>
                                </div>
                                <div class="flex flex-col w-[50%]">
                                    <label for="date_time_display" class="text-[16px] text-[#9E9E9E]">รับเข้าเมื่อ</label>
                                    <div class="relative">
                                        <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
                                            <svg class="w-4 h-4 text-[#1B3563]" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 10h16m-8-3V4M7 7V4m10 3V4M5 20h14a1 1 0 0 0 1-1V7a1 1 0 0 0-1-1H5a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1Z" />
                                            </svg>
                                        </div>
                                        <input datepicker datepicker-autohide datepicker-orientation="top left" datepicker-format="dd/mm/yyyy" id="date_time_display" type="text" class="block w-full pl-9 bg-[#F5F5F5] border-b-2 border-[#1B3563] h-[40px] outline-none p-3 text-[#1B3563]" placeholder="เลือกวันที่">
                                    </div>
                                </div>
                            </span>
                            <div class="mt-4">
                                <label for="comp_name" class=" text-[16px] text-[#9E9E9E]">ผู้ส่งสินค้า</label>
                                <input type="text" id="comp_name" name="comp_name" required class="bg-[#F5F5F5] border-b-2 border-[#1B3563] h-[40px] outline-0 p-3 w-[100%] text-[#1B3563]">
                            </div>
                        </div>
                    </div>
                    <div class="btn">
                        <div class="w-[100%] flex justify-end pt-5 gap-5">
                            <button type="submit" class="px-[32px] py-[12px] bg-[#1B3563] rounded-[8px] text-white hover:opacity-90 transition">ยืนยันการรับเข้า</button>
                            <button type="button" data-modal-hide="add-product-modal" class="px-[32px] py-[12px] bg-[#F00] rounded-[8px] text-white hover:opacity-90 transition">ยกเลิก</button>
                        </div>
                        </div>
                    </form>
            </div>
        </div>
    </div>
    </div>
    <script>
    document.getElementById('receivingForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const formData = new FormData(e.target);
        const data = Object.fromEntries(formData.entries());

        try {
            const response = await fetch('/api/receiving/add', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });

            const result = await response.json();
            if (result.success) {
                alert(result.message);
                window.location.reload();
            } else {
                alert('ล้มเหลว: ' + result.error);
            }
        } catch (err) {
            alert('เกิดข้อผิดพลาดในการเชื่อมต่อเซิร์ฟเวอร์');
        }
    });
    </script>
   <script src="/js/currentdate.js"></script>
</body>
</html>