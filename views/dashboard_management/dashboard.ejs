<!DOCTYPE html>
<html lang="th">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Prompt:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <style>
        body {
            font-family: 'Prompt', sans-serif;
            background-color: #0E1324;
            color: white;
        }
        ::-webkit-scrollbar { width: 8px; height: 8px; }
        ::-webkit-scrollbar-track { background: #0E1324; }
        ::-webkit-scrollbar-thumb { background: #1B2A47; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #4BA3E3; }
        .scrollbar-hide::-webkit-scrollbar { display: none; }
        .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
        input[type="date"] { color-scheme: dark; }
        ::-webkit-calendar-picker-indicator { cursor: pointer; filter: invert(0.8) sepia(1) hue-rotate(180deg) saturate(3); opacity: 0.7; }
        ::-webkit-calendar-picker-indicator:hover { opacity: 1; }
        .truncate-text { max-width: 150px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    </style>
</head>

<body class="overflow-x-hidden">

    <%- include('../partials/header_with_path', { path1: 'แดชบอร์ด' , url_1: '/dashboard' }) %>

    <% 
        let maxCapacity = typeof totalCapacity !== 'undefined' && totalCapacity > 0 ? totalCapacity : ((typeof totalInStock !== 'undefined' && totalInStock > 0) ? totalInStock * 1.5 : 100);
        let currentStock = typeof totalInStock !== 'undefined' ? totalInStock : 0;
        let capPercent = Math.round((currentStock / maxCapacity) * 100);
        if (capPercent > 100) capPercent = 100;
    %>

    <script id="dash-data" type="application/json">
        {
            "typeDist": <%- typeof typeDist !== 'undefined' ? JSON.stringify(typeDist) : '[]' %>,
            "monthlyTrans": <%- typeof monthlyTrans !== 'undefined' ? JSON.stringify(monthlyTrans) : '[]' %>,
            "topCategoriesOut": <%- typeof topCategoriesOut !== 'undefined' ? JSON.stringify(topCategoriesOut) : '[]' %>,
            "transIn": <%= (typeof transIn !== 'undefined' && transIn !== null) ? transIn : 0 %>,
            "transOut": <%= (typeof transOut !== 'undefined' && transOut !== null) ? transOut : 0 %>,
            "allProducts": <%- typeof allProducts !== 'undefined' ? JSON.stringify(allProducts) : '[]' %>,
            "popularProducts": <%- typeof popularProducts !== 'undefined' ? JSON.stringify(popularProducts) : '[]' %>,
            "warehouses": <%- typeof warehouses !== 'undefined' ? JSON.stringify(warehouses) : '[]' %>
        }
    </script>

    <div class="ml-0 lg:ml-[110px] mt-[80px] lg:mt-[100px] p-4 sm:p-6 lg:p-10 min-h-[calc(100vh-100px)] relative z-10">

        <div class="absolute right-0 lg:right-32 top-10 opacity-5 pointer-events-none hidden md:block">
            <i class="fa-solid fa-chart-line text-[200px] md:text-[300px] lg:text-[400px]"></i>
        </div>

        <div class="flex flex-col xl:flex-row justify-between items-start xl:items-end mb-6 lg:mb-8 relative z-20 gap-4 lg:gap-6">
            <div class="w-full xl:w-auto">
                <h1 class="text-[24px] md:text-[28px] lg:text-[32px] font-semibold mb-1">แดชบอร์ด</h1>
                <p class="text-[#999] text-xs lg:text-sm mb-4 lg:mb-6">สรุปข้อมูลการเคลื่อนไหวสินค้า ไว้ที่นี่</p>

                <div class="flex flex-col sm:flex-row sm:items-center gap-3 lg:gap-4 w-full">
                    <div class="flex items-center gap-2 lg:gap-3 w-full sm:w-auto">
                        <span class="text-[#999] text-[13px] lg:text-[15px] whitespace-nowrap">วันที่</span>
                        <input type="date" id="dashStartDate" value="<%= typeof query !== 'undefined' && query.start ? query.start : '' %>" 
                            class="bg-[#182642] text-[#69B4E3] border border-[#69B4E3]/30 px-3 py-1.5 rounded-md outline-none cursor-pointer hover:bg-[#1E2E4D] focus:border-[#4BA3E3] transition text-xs lg:text-sm w-full sm:w-auto">
                    </div>
                    <div class="flex items-center gap-2 lg:gap-3 w-full sm:w-auto">
                        <span class="text-[#999] text-[13px] lg:text-[15px] whitespace-nowrap">ถึง</span>
                        <input type="date" id="dashEndDate" value="<%= typeof query !== 'undefined' && query.end ? query.end : '' %>"
                            class="bg-[#182642] text-[#69B4E3] border border-[#69B4E3]/30 px-3 py-1.5 rounded-md outline-none cursor-pointer hover:bg-[#1E2E4D] focus:border-[#4BA3E3] transition text-xs lg:text-sm w-full sm:w-auto">
                    </div>
                    <button onclick="applyDashFilters()" class="bg-[#3fa9f5] hover:bg-[#1c92d2] text-white px-3 py-1.5 rounded-md transition text-xs lg:text-sm flex items-center justify-center gap-2 shadow-md w-full sm:w-auto">
                        <i class="fa-solid fa-magnifying-glass"></i> กรองวันที่
                    </button>
                </div>
            </div>

            <div class="flex flex-col items-start xl:items-end gap-4 w-full xl:w-auto mt-4 xl:mt-0">
                <button onclick="exportToCSV()" class="bg-[#ECC164] hover:bg-[#f0cf85] text-black font-semibold px-4 py-2 rounded-lg text-xs md:text-[13px] flex items-center justify-center gap-2 transition shadow-[0_0_10px_rgba(236,193,100,0.3)] w-full sm:w-auto">
                    <i class="fa-solid fa-file-export"></i> ส่งออกข้อมูล
                </button>

                <div class="flex w-full xl:w-auto border-b border-[#2A354D] overflow-x-auto scrollbar-hide">
                    <button onclick="switchTab('inventory')" id="tab-inventory" class="whitespace-nowrap tab-btn bg-[#182642] text-white px-5 sm:px-6 lg:px-8 py-2.5 font-medium rounded-t-lg border border-transparent shadow-[0_-5px_10px_rgba(0,0,0,0.1)] text-xs lg:text-sm transition flex-1 sm:flex-none text-center">รายงานคลัง</button>
                    <button onclick="switchTab('transition')" id="tab-transition" class="whitespace-nowrap tab-btn bg-transparent text-[#7A839E] hover:text-white px-5 sm:px-6 lg:px-8 py-2.5 font-medium text-xs lg:text-sm transition flex-1 sm:flex-none text-center">การรับ-จ่าย</button>
                    <button onclick="switchTab('popular')" id="tab-popular" class="whitespace-nowrap tab-btn bg-transparent text-[#7A839E] hover:text-white px-5 sm:px-6 lg:px-8 py-2.5 font-medium text-xs lg:text-sm transition flex-1 sm:flex-none text-center">รายการที่ใช้บ่อย</button>
                </div>
            </div>
        </div>

        <div id="content-inventory" class="tab-content w-full relative z-20 block">
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4 lg:gap-6 mb-6">
                <div class="bg-[#0A1020] border border-[#182642] p-4 lg:p-5 rounded-xl shadow-lg">
                    <h3 class="text-[#999] text-xs lg:text-[13px] mb-2">สินค้าทั้งหมด</h3>
                    <div class="flex items-baseline gap-2 mb-2"><span class="text-2xl lg:text-3xl font-bold"><%= typeof totalProducts !== 'undefined' ? totalProducts : 0 %></span><span class="text-xs lg:text-sm text-[#999]">รายการ</span></div>
                    <p class="text-[10px] lg:text-[11px] text-[#69B4E3]"><i class="fa-solid fa-arrow-trend-up"></i> ภาพรวมในระบบ</p>
                </div>
                <div class="bg-[#0A1020] border border-[#182642] p-4 lg:p-5 rounded-xl shadow-lg">
                    <h3 class="text-[#999] text-xs lg:text-[13px] mb-2">สินค้าคงเหลือ</h3>
                    <div class="flex items-baseline gap-2 mb-2"><span class="text-2xl lg:text-3xl font-bold"><%= typeof totalInStock !== 'undefined' ? totalInStock : 0 %></span><span class="text-xs lg:text-sm text-[#999]">ชิ้น</span></div>
                    <p class="text-[10px] lg:text-[11px] text-[#4ADE80]"><i class="fa-solid fa-box-open"></i> จำนวนชิ้นทั้งหมดในคลัง</p>
                </div>
                <div class="bg-[#0A1020] border border-[#182642] p-4 lg:p-5 rounded-xl shadow-lg sm:col-span-2 lg:col-span-1">
                    <h3 class="text-[#999] text-xs lg:text-[13px] mb-2">สินค้าหมดสต็อกแล้ว</h3>
                    <div class="flex items-baseline gap-2 mb-2"><span class="text-2xl lg:text-3xl font-bold"><%= typeof outOfStock !== 'undefined' ? outOfStock : 0 %></span><span class="text-xs lg:text-sm text-[#999]">รายการ</span></div>
                    <p class="text-[10px] lg:text-[11px] text-[#F87171]"><i class="fa-solid fa-circle-exclamation"></i> ต้องการสั่งซื้อเพิ่ม</p>
                </div>
            </div>

            <div class="grid grid-cols-1 xl:grid-cols-3 gap-4 lg:gap-6 mb-6 lg:mb-8">
                <div class="xl:col-span-2 bg-[#0A1020] border border-[#182642] p-4 lg:p-6 rounded-xl shadow-lg relative w-full overflow-hidden flex flex-col justify-between">
                    <div class="flex justify-between items-center mb-4">
                        <h3 class="text-sm lg:text-[15px] text-[#D4D4D4]">จำนวนสินค้าตามประเภท</h3>
                        <button class="text-[#999] hover:text-white"><i class="fa-solid fa-expand"></i></button>
                    </div>
                    <div class="relative w-full h-[320px]">
                        <canvas id="categoryChart"></canvas>
                    </div>
                </div>

                <div class="flex flex-col gap-4 lg:gap-6">
                    <div class="bg-[#0A1020] border border-[#182642] p-4 lg:p-5 rounded-xl shadow-lg flex-1">
                        <div class="flex justify-between items-center mb-4">
                            <h3 class="text-xs lg:text-[13px] text-[#999]">ความจุคลัง</h3>
                            <select id="warehouseSelect" onchange="updateCapacity()" class="bg-[#182642] text-white text-[10px] lg:text-[11px] px-2 py-1 rounded outline-none border border-[#2A354D] cursor-pointer">
                                <option value="all">คลังรวม</option>
                                <% if(typeof warehouses !== 'undefined' && warehouses.length > 0) { %>
                                    <% warehouses.forEach(wh => { %>
                                        <option value="<%= wh.wh_id %>"><%= wh.wh_name %></option>
                                    <% }) %>
                                <% } %>
                            </select>
                        </div>
                        <div class="flex gap-4 lg:gap-6 h-[120px] lg:h-[160px] items-end pb-2">
                            <div class="w-16 sm:w-20 lg:w-24 bg-[#182642] rounded-xl relative overflow-hidden flex flex-col justify-end border border-[#2A354D] h-full">
                                <div id="capBar" class="w-full bg-[#4ADE80] flex items-center justify-center transition-all duration-1000" style="height: <%= capPercent %>%;">
                                    <span id="capText" class="text-[#FFFFFF] font-bold text-lg lg:text-2xl pb-3"><%= capPercent %>%</span>
                                </div>
                            </div>
                            <div class="flex flex-col justify-center gap-1 text-[11px] sm:text-xs lg:text-[13px] h-full">
                                <p class="text-white mb-1">ใช้งานแล้ว <span id="usedStock" class="font-bold text-[#69B4E3]">0</span> ชิ้น</p>
                                <p class="text-white mb-1 lg:mb-2">ความจุรวม <span id="maxStock" class="font-bold text-[#FCD34D]">0</span> ชิ้น</p>
                                <div class="mt-1 lg:mt-2 text-[#D4D4D4] text-[10px] sm:text-[11px] lg:text-[12px]">สถานะพื้นที่ <br><span id="capStatus" class="font-bold text-[#6EE7B7]">กำลังโหลด..</span></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="bg-[#0A1020] border border-[#182642] rounded-xl overflow-hidden shadow-2xl mb-6 lg:mb-8">
                <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center p-4 lg:p-5 border-b border-[#2A354D] gap-4 sm:gap-0">
                    <h3 class="text-sm lg:text-[15px] font-semibold">รายการสินค้าทั้งหมด</h3>
                    <div class="w-full sm:w-auto flex justify-end">
                        <div class="relative flex items-center bg-[#182642] rounded-full pl-4 border border-[#2A354D] overflow-hidden w-full sm:w-auto">
                            <input type="text" id="dashSearchInput" placeholder="ค้นหา ชื่อสินค้า, รหัส" value="<%= typeof query !== 'undefined' && query.search ? query.search : '' %>" onkeypress="if(event.key === 'Enter') applyDashFilters()" class="bg-transparent border-none outline-none text-[11px] lg:text-[12px] text-white w-full sm:w-[150px] lg:w-[180px] placeholder-[#666] py-1.5 lg:py-0">
                            <button onclick="applyDashFilters()" class="bg-[#3fa9f5] w-[35px] h-[28px] lg:h-[30px] flex items-center justify-center hover:bg-blue-400 transition"><i class="fa-solid fa-magnifying-glass text-white text-xs"></i></button>
                        </div>
                    </div>
                </div>

                <div class="overflow-x-auto max-h-[300px] lg:max-h-[400px]">
                    <table class="w-full text-left text-xs lg:text-[13px] whitespace-nowrap">
                        <thead class="bg-[#182642] text-[#69B4E3] sticky top-0 z-10 shadow-sm">
                            <tr>
                                <th class="px-4 lg:px-5 py-2.5 lg:py-3 font-normal border-r border-[#2A354D]/50 w-[60px]">รหัสสินค้า</th>
                                <th class="px-4 lg:px-5 py-2.5 lg:py-3 font-normal border-r border-[#2A354D]/50">ชื่อสินค้า</th>
                                <th class="px-4 lg:px-5 py-2.5 lg:py-3 font-normal border-r border-[#2A354D]/50">แบรนด์</th>
                                <th class="px-4 lg:px-5 py-2.5 lg:py-3 font-normal border-r border-[#2A354D]/50">ประเภท</th>
                                <th class="px-4 lg:px-5 py-2.5 lg:py-3 font-normal text-center">จำนวนคงเหลือ</th>
                            </tr>
                        </thead>
                        <tbody class="text-[#D4D4D4]">
                            <% if(typeof allProducts !== 'undefined' && allProducts.length > 0) { %>
                                <% allProducts.forEach(item=> { %>
                                    <tr class="border-b border-[#182642] hover:bg-[#182642]/50 transition">
                                        <td class="px-4 lg:px-5 py-2.5 lg:py-3 border-r border-[#182642]"><%= item.prod_code %></td>
                                        <td class="px-4 lg:px-5 py-2.5 lg:py-3 border-r border-[#182642]">
                                            <div class="flex items-center gap-2 lg:gap-3">
                                                <div class="w-5 h-5 lg:w-6 lg:h-6 bg-white rounded-full flex items-center justify-center p-0.5 lg:p-1 shrink-0 overflow-hidden">
                                                    <img src="<%= item.prod_img %>" onerror="this.onerror=null;" class="object-contain w-full h-full">
                                                </div>
                                                <span class="truncate-text"><%= item.prod_name %></span>
                                            </div>
                                        </td>
                                        <td class="px-4 lg:px-5 py-2.5 lg:py-3 border-r border-[#182642]"><%= item.brand %></td>
                                        <td class="px-4 lg:px-5 py-2.5 lg:py-3 border-r border-[#182642]"><%= item.prod_type %></td>
                                        <td class="px-4 lg:px-5 py-2.5 lg:py-3 text-center"><%= item.amount %></td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="5" class="text-center py-6 text-gray-500">ไม่มีข้อมูลสินค้า</td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div id="content-transition" class="tab-content w-full relative z-20 hidden">
            <div class="flex justify-between items-center border-b border-[#2A354D] pb-3 lg:pb-4 mb-4 lg:mb-6">
                <h2 class="text-base lg:text-lg font-semibold">รายงานการรับจ่ายสินค้า</h2>
                <a href="/transactions" class="bg-[#182642] border border-[#2A354D] text-[10px] lg:text-xs px-3 py-1.5 lg:px-4 lg:py-2 rounded-lg hover:bg-[#1E2E4D] transition whitespace-nowrap"><i class="fa-solid fa-clock-rotate-left mr-1 lg:mr-2"></i> ดูประวัติทั้งหมด</a>
            </div>

            <div class="grid grid-cols-2 md:grid-cols-4 gap-3 lg:gap-6 mb-6 lg:mb-8">
                <div class="bg-[#0A1020] border border-[#182642] p-4 lg:p-5 rounded-xl shadow-lg">
                    <h3 class="text-[#999] text-[11px] lg:text-[13px] mb-1 lg:mb-2 whitespace-nowrap">สินค้ารับเข้าทั้งหมด</h3>
                    <div class="flex items-baseline gap-1 lg:gap-2 mb-1 lg:mb-2"><span class="text-xl sm:text-2xl lg:text-3xl font-bold"><%= typeof transIn !== 'undefined' ? transIn : 0 %></span><span class="text-[10px] lg:text-xs text-[#999]">ชิ้น</span></div>
                    <p class="text-[9px] lg:text-[11px] text-[#69B4E3]"><i class="fa-solid fa-arrow-right-to-bracket"></i> ประวัติรับเข้า</p>
                </div>
                <div class="bg-[#0A1020] border border-[#182642] p-4 lg:p-5 rounded-xl shadow-lg">
                    <h3 class="text-[#999] text-[11px] lg:text-[13px] mb-1 lg:mb-2 whitespace-nowrap">สินค้าจ่ายออกทั้งหมด</h3>
                    <div class="flex items-baseline gap-1 lg:gap-2 mb-1 lg:mb-2"><span class="text-xl sm:text-2xl lg:text-3xl font-bold"><%= typeof transOut !== 'undefined' ? transOut : 0 %></span><span class="text-[10px] lg:text-xs text-[#999]">ชิ้น</span></div>
                    <p class="text-[9px] lg:text-[11px] text-[#F87171]"><i class="fa-solid fa-arrow-right-from-bracket"></i> ประวัติเบิกจ่าย</p>
                </div>
                <div class="bg-[#0A1020] border border-[#182642] p-4 lg:p-5 rounded-xl shadow-lg">
                    <h3 class="text-[#999] text-[11px] lg:text-[13px] mb-1 lg:mb-2 whitespace-nowrap">รายการปรับแก้ไข</h3>
                    <div class="flex items-baseline gap-1 lg:gap-2 mb-1 lg:mb-2"><span class="text-xl sm:text-2xl lg:text-3xl font-bold"><%= typeof transAdj !== 'undefined' ? transAdj : 0 %></span><span class="text-[10px] lg:text-xs text-[#999]">รายการ</span></div>
                    <p class="text-[9px] lg:text-[11px] text-[#FCD34D]"><i class="fa-solid fa-pen-to-square"></i> ประวัติปรับปรุง</p>
                </div>
                <div class="bg-[#0A1020] border border-[#182642] p-4 lg:p-5 rounded-xl shadow-lg">
                    <h3 class="text-[#999] text-[11px] lg:text-[13px] mb-1 lg:mb-2 whitespace-nowrap">ยอดสุทธิรวม</h3>
                    <div class="flex items-baseline gap-1 lg:gap-2 mb-1 lg:mb-2">
                        <% const diff = (typeof transIn !== 'undefined' ? transIn : 0) - (typeof transOut !== 'undefined' ? transOut : 0); %>
                        <span class="text-xl sm:text-2xl lg:text-3xl font-bold <%= diff >= 0 ? 'text-[#4ADE80]' : 'text-[#F87171]' %>">
                            <%= diff > 0 ? '+' : '' %><%= diff %>
                        </span>
                        <span class="text-[10px] lg:text-xs text-[#999]">ชิ้น</span>
                    </div>
                    <p class="text-[9px] lg:text-[11px] text-[#999]">ส่วนต่างรับเข้า-ออก</p>
                </div>
            </div>

            <div class="grid grid-cols-1 xl:grid-cols-3 gap-4 lg:gap-6 mb-6 lg:mb-8">
                <div class="xl:col-span-2 bg-[#0A1020] border border-[#182642] p-4 lg:p-6 rounded-xl shadow-lg w-full overflow-hidden">
                    <div class="flex justify-between items-center mb-4 lg:mb-6">
                        <h3 class="text-sm lg:text-[15px] text-[#D4D4D4]">แนวโน้มรับเข้า-จ่ายออก รายเดือน</h3>
                    </div>
                    <div class="relative h-[200px] sm:h-[250px] lg:h-[300px] w-full">
                        <canvas id="trendChart"></canvas>
                    </div>
                </div>

                <div class="flex flex-col gap-4 lg:gap-6">
                    <div class="bg-[#0A1020] border border-[#182642] p-4 lg:p-5 rounded-xl shadow-lg flex-1 w-full overflow-hidden">
                        <h3 class="text-[11px] lg:text-[13px] text-[#D4D4D4] mb-2 lg:mb-4">สัดส่วนการทำรายการ</h3>
                        <div class="relative h-[120px] sm:h-[150px] w-full flex justify-center"><canvas id="receiveCompareChart"></canvas></div>
                    </div>
                </div>
            </div>
        </div>

        <div id="content-popular" class="tab-content w-full relative z-20 hidden">
            <h2 class="text-base lg:text-lg font-semibold border-b border-[#2A354D] pb-3 lg:pb-4 mb-4 lg:mb-6">รายงานการใช้บ่อย</h2>

            <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-4 lg:gap-6 mb-6 lg:mb-8">
                <div class="xl:col-span-2 bg-gradient-to-br from-[#182642] to-[#0A1020] border border-[#2A354D] p-5 lg:p-6 rounded-xl shadow-lg flex flex-col justify-center">
                    <h3 class="text-[#999] text-xs lg:text-[13px] mb-2">สินค้ายอดนิยมที่มีการเบิกมากที่สุด</h3>
                    <h2 class="text-xl sm:text-2xl lg:text-3xl font-bold text-white mb-2 line-clamp-1">
                        <%= (typeof popularProducts !== 'undefined' && popularProducts.length > 0) ? popularProducts[0].prod_name : 'ไม่มีข้อมูล' %>
                    </h2>
                    <div class="flex items-center gap-3 lg:gap-4 text-[11px] lg:text-sm">
                        <span class="text-[#D4D4D4]">ประเภท <%= (typeof popularProducts !== 'undefined' && popularProducts.length > 0) ? popularProducts[0].prod_type : '-' %></span>
                        <span class="text-[#69B4E3]"><i class="fa-solid fa-arrow-trend-up"></i> ยอดเบิกสะสม <%= (typeof popularProducts !== 'undefined' && popularProducts.length > 0) ? popularProducts[0].total_out : 0 %> ชิ้น</span>
                    </div>
                </div>

                <div class="bg-[#0A1020] border border-[#182642] p-5 lg:p-6 rounded-xl shadow-lg flex flex-col justify-center">
                    <h3 class="text-[#999] text-xs lg:text-[13px] mb-2">รายการยอดฮิต</h3>
                    <div class="flex items-baseline gap-2 mb-1"><span class="text-2xl lg:text-3xl font-bold"><%= typeof popularProducts !== 'undefined' ? popularProducts.length : 0 %></span><span class="text-xs lg:text-sm text-[#999]">รายการ</span></div>
                    <p class="text-[10px] lg:text-[11px] text-[#999]">ที่มีการเบิกออกบ่อยสุด</p>
                </div>
            </div>

            <div class="bg-[#0A1020] border border-[#182642] p-4 lg:p-6 rounded-xl shadow-lg mb-6 lg:mb-8 w-full overflow-hidden">
                <div class="flex justify-between items-center mb-4 lg:mb-6">
                    <h3 class="text-sm lg:text-[15px] text-[#D4D4D4]">อันดับประเภทสินค้าที่ถูกเบิกมากที่สุด</h3>
                </div>
                <div class="relative h-[200px] sm:h-[250px] w-full">
                    <canvas id="topCategoriesChart"></canvas>
                </div>
            </div>

            <div class="bg-[#0A1020] border border-[#182642] rounded-xl overflow-hidden shadow-2xl mb-6 lg:mb-8">
                <div class="flex justify-between items-center p-4 lg:p-5 border-b border-[#2A354D]">
                    <h3 class="text-sm lg:text-[15px] font-semibold">อันดับรายการสินค้าเบิกออกสูงสุด</h3>
                </div>
                <div class="overflow-x-auto">
                    <table class="w-full text-left text-xs lg:text-[13px] whitespace-nowrap">
                        <thead class="bg-[#182642] text-[#69B4E3]">
                            <tr>
                                <th class="px-4 lg:px-5 py-2.5 lg:py-3 font-normal border-r border-[#2A354D]/50 w-[50px] lg:w-[60px]">อันดับ</th>
                                <th class="px-4 lg:px-5 py-2.5 lg:py-3 font-normal border-r border-[#2A354D]/50">ชื่อสินค้า</th>
                                <th class="px-4 lg:px-5 py-2.5 lg:py-3 font-normal border-r border-[#2A354D]/50">แบรนด์</th>
                                <th class="px-4 lg:px-5 py-2.5 lg:py-3 font-normal border-r border-[#2A354D]/50">รหัสสินค้า</th>
                                <th class="px-4 lg:px-5 py-2.5 lg:py-3 font-normal border-r border-[#2A354D]/50">ประเภท</th>
                                <th class="px-4 lg:px-5 py-2.5 lg:py-3 font-normal text-center">จำนวนยอดเบิกสะสม</th>
                            </tr>
                        </thead>
                        <tbody class="text-[#D4D4D4]">
                            <% if(typeof popularProducts !== 'undefined' && popularProducts.length > 0) { %>
                                <% popularProducts.forEach((item, index)=> { %>
                                    <tr class="border-b border-[#182642] hover:bg-[#182642]/50 transition">
                                        <td class="px-4 lg:px-5 py-2.5 lg:py-3 border-r border-[#182642]"><%= index + 1 %></td>
                                        <td class="px-4 lg:px-5 py-2.5 lg:py-3 border-r border-[#182642]">
                                            <div class="flex items-center gap-2 lg:gap-3">
                                                <div class="w-5 h-5 lg:w-6 lg:h-6 bg-white rounded-full flex items-center justify-center p-0.5 lg:p-1 shrink-0 overflow-hidden">
                                                    <img src="<%= item.prod_img %>" onerror="this.onerror=null;" class="object-contain w-full h-full">
                                                </div>
                                                <span class="truncate-text"><%= item.prod_name %></span>
                                            </div>
                                        </td>
                                        <td class="px-4 lg:px-5 py-2.5 lg:py-3 border-r border-[#182642]"><%= item.brand %></td>
                                        <td class="px-4 lg:px-5 py-2.5 lg:py-3 border-r border-[#182642]"><%= item.prod_code %></td>
                                        <td class="px-4 lg:px-5 py-2.5 lg:py-3 border-r border-[#182642]"><%= item.prod_type %></td>
                                        <td class="px-4 lg:px-5 py-2.5 lg:py-3 text-center text-[#F87171] font-bold"><%= item.total_out %></td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="6" class="text-center py-6 text-gray-500">ไม่มีข้อมูล</td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <script>
        let currentActiveTab = 'inventory';

        function switchTab(tabId) {
            currentActiveTab = tabId;
            document.querySelectorAll('.tab-content').forEach(el => {
                el.classList.add('hidden');
                el.classList.remove('block');
            });
            document.querySelectorAll('.tab-btn').forEach(btn => {
                btn.className = "whitespace-nowrap tab-btn bg-transparent text-[#7A839E] hover:text-white px-5 sm:px-6 lg:px-8 py-2.5 font-medium text-xs lg:text-sm transition flex-1 sm:flex-none text-center";
            });

            document.getElementById('content-' + tabId).classList.remove('hidden');
            document.getElementById('content-' + tabId).classList.add('block');
            document.getElementById('tab-' + tabId).className = "whitespace-nowrap tab-btn bg-[#182642] text-white px-5 sm:px-6 lg:px-8 py-2.5 font-medium rounded-t-lg border border-transparent shadow-[0_-5px_10px_rgba(0,0,0,0.1)] text-xs lg:text-sm transition flex-1 sm:flex-none text-center";

            if (tabId === 'inventory' && charts.category) charts.category.update();
            if (tabId === 'transition') {
                if (charts.trend) charts.trend.update();
                if (charts.rxComp) charts.rxComp.update();
            }
            if (tabId === 'popular' && charts.topCat) charts.topCat.update();
        }

        function exportToCSV() {
            try {
                const rawData = document.getElementById('dash-data').textContent;
                const dbData = JSON.parse(rawData);
                
                let csvContent = "\uFEFF"; 
                let filename = "export.csv";
                const escapeCSV = (str) => String(str).replace(/"/g, '""');

                if (currentActiveTab === 'inventory') {
                    filename = "รายงานคลังสินค้า.csv";
                    csvContent += "รหัสสินค้า,ชื่อสินค้า,แบรนด์,ประเภท,จำนวนคงเหลือ\n";
                    dbData.allProducts.forEach(item => {
                        csvContent += `"${escapeCSV(item.prod_code)}","${escapeCSV(item.prod_name)}","${escapeCSV(item.brand)}","${escapeCSV(item.prod_type)}","${item.amount}"\n`;
                    });
                } else if (currentActiveTab === 'transition') {
                    filename = "รายงานแนวโน้มการรับจ่ายรายเดือน.csv";
                    csvContent += "เดือน,ประเภทการทำรายการ,จำนวน(ชิ้น)\n";
                    const monthsMap = { 1: 'ม.ค.', 2: 'ก.พ.', 3: 'มี.ค.', 4: 'เม.ย.', 5: 'พ.ค.', 6: 'มิ.ย.', 7: 'ก.ค.', 8: 'ส.ค.', 9: 'ก.ย.', 10: 'ต.ค.', 11: 'พ.ย.', 12: 'ธ.ค.' };
                    dbData.monthlyTrans.forEach(item => {
                        let monthName = monthsMap[item.month] || item.month;
                        let typeName = item.type === 'IN' ? 'รับเข้า' : 'จ่ายออก';
                        csvContent += `"${monthName}","${typeName}","${item.sum}"\n`;
                    });
                } else if (currentActiveTab === 'popular') {
                    filename = "รายงานสินค้ายอดนิยม.csv";
                    csvContent += "อันดับ,รหัสสินค้า,ชื่อสินค้า,แบรนด์,ประเภท,จำนวนยอดเบิกสะสม(ชิ้น)\n";
                    dbData.popularProducts.forEach((item, index) => {
                        csvContent += `"${index + 1}","${escapeCSV(item.prod_code)}","${escapeCSV(item.prod_name)}","${escapeCSV(item.brand)}","${escapeCSV(item.prod_type)}","${item.total_out}"\n`;
                    });
                }

                const blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
                const link = document.createElement("a");
                const url = URL.createObjectURL(blob);
                link.setAttribute("href", url);
                link.setAttribute("download", filename);
                link.style.visibility = 'hidden';
                document.body.appendChild(link);
                link.click();
                document.body.removeChild(link);

            } catch (error) {
                console.error("Error exporting CSV:", error);
                alert("เกิดข้อผิดพลาดในการส่งออกข้อมูล");
            }
        }

        function updateCapacity() {
            try {
                const rawData = document.getElementById('dash-data').textContent;
                const dbData = JSON.parse(rawData);
                const whId = document.getElementById('warehouseSelect').value;
                
                let currentStock = 0;
                let maxCap = 0;
                
                if (whId === 'all' || whId === '') {
                    dbData.warehouses.forEach(w => {
                        currentStock += Number(w.current_stock) || 0;
                        maxCap += Number(w.max_capacity) || 0;
                    });
                } else {
                    const selectedWh = dbData.warehouses.find(w => String(w.wh_id) === String(whId));
                    if (selectedWh) {
                        currentStock = Number(selectedWh.current_stock) || 0;
                        maxCap = Number(selectedWh.max_capacity) || 0;
                    }
                }
                
                if(maxCap === 0) maxCap = currentStock > 0 ? currentStock * 2 : 100;
                
                let percent = Math.round((currentStock / maxCap) * 100);
                if (percent > 100) percent = 100;
                
                const capBar = document.getElementById('capBar');
                const capText = document.getElementById('capText');
                const capStatus = document.getElementById('capStatus');
                
                capBar.style.height = percent + '%';
                capText.innerText = percent + '%';
                document.getElementById('usedStock').innerText = currentStock.toLocaleString();
                document.getElementById('maxStock').innerText = maxCap.toLocaleString();
                
                if (percent >= 90) {
                    capBar.className = "w-full flex items-center justify-center transition-all duration-1000 bg-[#F87171]";
                    capStatus.innerText = "หนาแน่น";
                    capStatus.className = "font-bold text-[#F87171]";
                } else if (percent >= 70) {
                    capBar.className = "w-full flex items-center justify-center transition-all duration-1000 bg-[#FCD34D]";
                    capStatus.innerText = "ปานกลาง";
                    capStatus.className = "font-bold text-[#FCD34D]";
                } else {
                    capBar.className = "w-full flex items-center justify-center transition-all duration-1000 bg-[#6EE7B7]";
                    capStatus.innerText = "ปกติ (ว่าง)";
                    capStatus.className = "font-bold text-[#6EE7B7]";
                }
            } catch (error) {
                console.error("Error updating capacity:", error);
            }
        }

        function applyDashFilters() {
            const startDate = document.getElementById('dashStartDate').value;
            const endDate = document.getElementById('dashEndDate').value;
            const searchInput = document.getElementById('dashSearchInput');
            
            let url = new URL(window.location.href);

            if (startDate) url.searchParams.set('start', startDate);
            else url.searchParams.delete('start');

            if (endDate) url.searchParams.set('end', endDate);
            else url.searchParams.delete('end');

            if (searchInput && searchInput.value) url.searchParams.set('search', searchInput.value);
            else url.searchParams.delete('search');

            window.location.href = url.href;
        }

        const charts = {};

        document.addEventListener('DOMContentLoaded', function () {
            
            updateCapacity();

            const rawData = document.getElementById('dash-data').textContent;
            const dbData = JSON.parse(rawData);
            
            const typeDistData = dbData.typeDist || [];
            const monthlyData = dbData.monthlyTrans || [];
            const topCatData = dbData.topCategoriesOut || [];
            const totalIn = Number(dbData.transIn) || 0;
            const totalOut = Number(dbData.transOut) || 0;

            Chart.defaults.color = '#999';
            Chart.defaults.font.family = 'Prompt';

            const ctxCat = document.getElementById('categoryChart').getContext('2d');
            charts.category = new Chart(ctxCat, {
                type: 'bar',
                data: {
                    labels: typeDistData.length > 0 ? typeDistData.map(d => d.prod_type || 'ไม่ระบุ') : ['ไม่มีข้อมูล'],
                    datasets: [{
                        label: 'จำนวน',
                        data: typeDistData.length > 0 ? typeDistData.map(d => Number(d.sum) || 0) : [0],
                        backgroundColor: ['#FCD34D', '#EF4444', '#C084FC', '#818CF8', '#FB7185'],
                        borderRadius: 4,
                        maxBarThickness: 50,
                    }]
                },
                options: {
                    responsive: true, 
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        x: { grid: { display: false }, ticks: { font: { size: window.innerWidth < 640 ? 10 : 12 } } },
                        y: { beginAtZero: true, grid: { color: '#2A354D' }, border: { display: false }, ticks: { font: { size: window.innerWidth < 640 ? 10 : 12 } } }
                    }
                }
            });

            const monthsMap = { 1: 'ม.ค.', 2: 'ก.พ.', 3: 'มี.ค.', 4: 'เม.ย.', 5: 'พ.ค.', 6: 'มิ.ย.', 7: 'ก.ค.', 8: 'ส.ค.', 9: 'ก.ย.', 10: 'ต.ค.', 11: 'พ.ย.', 12: 'ธ.ค.' };
            let uniqMonths = [...new Set(monthlyData.map(d => d.month))].sort((a, b) => a - b);
            let labelsMonth = uniqMonths.map(m => monthsMap[m] || m);

            let dataIn = uniqMonths.map(m => {
                let found = monthlyData.find(d => d.month === m && d.type === 'IN');
                return found ? Number(found.sum) : 0;
            });
            let dataOut = uniqMonths.map(m => {
                let found = monthlyData.find(d => d.month === m && d.type === 'issue');
                return found ? Number(found.sum) : 0;
            });

            const ctxTrend = document.getElementById('trendChart').getContext('2d');
            let gradGreen = ctxTrend.createLinearGradient(0, 0, 0, 300);
            gradGreen.addColorStop(0, 'rgba(110, 231, 183, 0.3)');
            gradGreen.addColorStop(1, 'rgba(110, 231, 183, 0)');

            let gradRed = ctxTrend.createLinearGradient(0, 0, 0, 300);
            gradRed.addColorStop(0, 'rgba(248, 113, 113, 0.3)');
            gradRed.addColorStop(1, 'rgba(248, 113, 113, 0)');

            charts.trend = new Chart(ctxTrend, {
                type: 'line',
                data: {
                    labels: labelsMonth.length > 0 ? labelsMonth : ['ไม่มีข้อมูล'],
                    datasets: [
                        { label: 'รับเข้า', data: dataIn.length > 0 ? dataIn : [0], borderColor: '#6EE7B7', backgroundColor: gradGreen, tension: 0.4, fill: true, pointBackgroundColor: '#6EE7B7', borderWidth: 2, pointRadius: window.innerWidth < 640 ? 2 : 4 },
                        { label: 'จ่ายออก', data: dataOut.length > 0 ? dataOut : [0], borderColor: '#EF4444', backgroundColor: gradRed, tension: 0.4, fill: true, pointBackgroundColor: '#EF4444', borderWidth: 2, pointRadius: window.innerWidth < 640 ? 2 : 4 }
                    ]
                },
                options: {
                    responsive: true, maintainAspectRatio: false,
                    plugins: { legend: { position: 'top', align: 'end', labels: { color: '#fff', boxWidth: 12, padding: 10, font: { size: window.innerWidth < 640 ? 10 : 12 } } } },
                    scales: {
                        x: { grid: { color: '#2A354D' }, border: { display: false }, ticks: { font: { size: window.innerWidth < 640 ? 10 : 12 } } },
                        y: { beginAtZero: true, grid: { color: '#2A354D' }, border: { display: false }, ticks: { font: { size: window.innerWidth < 640 ? 10 : 12 } } }
                    }
                }
            });

            const ctxRx = document.getElementById('receiveCompareChart').getContext('2d');
            charts.rxComp = new Chart(ctxRx, {
                type: 'doughnut',
                data: {
                    labels: ['รับเข้า', 'จ่ายออก'],
                    datasets: [{
                        data: [(totalIn === 0 && totalOut === 0) ? 1 : totalIn, totalOut],
                        backgroundColor: [(totalIn === 0 && totalOut === 0) ? '#2A354D' : '#6EE7B7', '#F87171'],
                        borderWidth: 0,
                        hoverOffset: 2
                    }]
                },
                options: {
                    responsive: true, maintainAspectRatio: false,
                    plugins: { 
                        legend: { position: 'right', labels: { color: '#999', boxWidth: 10, font: { size: 10 } } },
                        tooltip: { enabled: (totalIn !== 0 || totalOut !== 0) }
                    },
                    cutout: '75%',
                    layout: { padding: 0 }
                }
            });

            const ctxTopCat = document.getElementById('topCategoriesChart').getContext('2d');
            charts.topCat = new Chart(ctxTopCat, {
                type: 'bar',
                data: {
                    labels: topCatData.length > 0 ? topCatData.map(d => d.prod_type || 'ไม่ระบุ') : ['ไม่มีข้อมูล'],
                    datasets: [{
                        data: topCatData.length > 0 ? topCatData.map(d => Number(d.total_out) || 0) : [0],
                        backgroundColor: ['#FCD34D', '#6EE7B7', '#F472B6', '#EF4444', '#A855F7', '#86EFAC'],
                        borderRadius: 4,
                        maxBarThickness: 30
                    }]
                },
                options: {
                    indexAxis: 'y',
                    responsive: true, maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        x: { beginAtZero: true, grid: { color: '#2A354D' }, border: { display: false }, ticks: { font: { size: window.innerWidth < 640 ? 10 : 12 } } },
                        y: { grid: { display: false }, ticks: { color: '#D4D4D4', font: { size: window.innerWidth < 640 ? 10 : 12 } } }
                    }
                }
            });

        });
    </script>
</body>
</html>