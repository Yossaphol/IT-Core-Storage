<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Warehouse</title>
    <style>
        /* เปลี่ยนสีพื้นหลัง CSS ให้ตรงกับ Three.js */
        body { margin: 0; overflow: hidden; background-color: #0E1324; }
        canvas { display: block; }
    </style>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Prompt:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&family=SN+Pro:ital,wght@0,200..900;1,200..900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/font.css">
    <script src="/stock_management/stock_editing.js" defer></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body>
    <div class="relative z-20 pointer-events-none">
        <%- include('../partials/header_with_path', { path1 : "การจัดการคลัง", url_1 : "/warehouse_management", 
                                                        path2 : "แก้ไขคลังสินค้า", url_2 : "/warehouse_management/edit",
                                                        path3 : "แก้ไขโซนเก็บสินค้า", url_3 : "/warehouse_management/stock/edit"}) %>
    </div>
    <div class="absolute top-[17%] left-[10%]">
        <p class="text-white text-[40px]">แก้ไขโซนเก็บสินค้า</p>
        <p class="text-white text-[14px]">แก้ไข ข้อมูลโซนเก็บสินค้า ได้ที่นี่</p>
    </div>

    <!-- form -->
    <div class="w-[790px] h-[790px] bg-white absolute left-[25%] top-[30%] rounded-[30px] flex flex-col p-10">
        <div class="w-[100%] mb-2">
            <p class="text-[48px] text-[#0E1324] flex gap-5">โซนเก็บสินค้า <%= stock.stock_name %></p>
        </div>
        <div class="bg-[#4BA3E3]/50 w-[700px] h-[1px]"></div>
        <div class="mt-5 flex justify-between w-[100%]">
            <input type="hidden" id="stockId" value="<%= stock.stock_id %>">
            <input type="hidden" id="warehouseId" value="<%= stock.wh_id %>">
            <div class="flex flex-col w-[48%]">
                <label for="name" class="text-[#9E9E9E] text-[16px]" value="<%= stock.stock_name %>">ชื่อโซนเก็บสินค้าใหม่</label>
                <input value="<%= stock.stock_name %>" type="text" name="name" id="name" required minlength="2" class="bg-[#F5F5F5] border-b-2 border-[#1B3563] h-[40px] outline-0 p-3 w-[100%]">
            </div>
            <div class="flex flex-col w-[48%]">
                <label for="capacity" class="text-[#9E9E9E] text-[16px]" value="<%= stock.capacity %>">ความจุโซนเก็บสินค้าสูงสุด</label>
                <input value="<%= stock.capacity %>" type="text" name="capacity" id="capacity" min="1" required class="bg-[#F5F5F5] border-b-2 border-[#1B3563] h-[40px] outline-0 p-3 w-[100%]">
            </div>
        </div>
        <div class="mt-10 text-white text-[20px] flex gap-3 justify-end">
            <button id="confirm" class="w-[130px] h-[50px] bg-[#1B3563] rounded-lg">ยืนยัน</button>
            <button id="cancel" class="w-[130px] h-[50px] bg-[#FF0000] rounded-lg">ยกเลิก</button>
        </div>
    </div>
    <i class="fa-solid fa-warehouse text-white text-[400px] opacity-[6%] absolute top-[12%] right-[7%] -z-10"></i>
</body>
</html>