<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Product Management</title>
    <style>
        body { margin: 0; overflow: auto; background-color: #0E1324; }
        canvas { display: block; }

        .custom-check {
            appearance: none; -webkit-appearance: none;
            width: 1.3rem; height: 1.3rem;
            border: 2px solid #6b7280; border-radius: 0.3rem;
            background-color: transparent; cursor: pointer;
            position: relative; transition: all 0.15s ease;
        }
        .custom-check:checked { background-color: #22c55e; border-color: #22c55e; }
        .custom-check:checked::after {
            font-family: "Font Awesome 6 Free";
            font-weight: 900;
            content: '\f00c'; position: absolute; top: 50%; left: 50%;
            transform: translate(-50%, -50%); color: white; font-size: 0.8rem; font-weight: bold;
        }
        .custom-scroll::-webkit-scrollbar { width: 5px; }
        .custom-scroll::-webkit-scrollbar-track { background: transparent; }
        .custom-scroll::-webkit-scrollbar-thumb { background: #2a3a6e; border-radius: 3px; }
    </style>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="https://cdn-uicons.flaticon.com/uicons-bold-rounded/css/uicons-bold-rounded.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Prompt:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&family=SN+Pro:ital,wght@0,200..900;1,200..900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/font.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/flowbite@latest/dist/flowbite.min.js"></script>
</head>
<body>
    
    <div class="relative z-20 pointer-events-none">
        <%- include('../partials/header_with_path', { path1 : "การจัดการสินค้า", url_1 : "/product_management"}) %>
    </div>
    <div class="absolute top-[17%] left-[12%]">
        <p class="text-white text-[40px]">การจัดการสินค้า</p>
        <p class="text-gray-400 text-[15px] font-light">เพิ่ม / แก้ไข / ลบ ข้อมูลสินค้า ได้ที่นี่</p>
    </div>

    <img class="fixed w-70 right-10 top-0" src="/images/chklist.png" alt="">

    <div class="absolute top-[37%] inset-x-[12%] right-[10%] flex items-start justify-between">
        
        <div class="flex h-14 items-center">
            <p class="text-white text-[20px]">สินค้าทั้งหมด <%= total %> รายการ</p>
        </div>
                
        <div class="flex items-start gap-5">

            <!-- Search Bar -->
            <div class="relative flex h-14 w-[500px] items-center overflow-hidden rounded-full border border-[#4BA3E3]/20 bg-transparent">
                <input type="text" id="searchInput" placeholder="ค้นหา ชื่อ, รหัสสินค้า" 
                    class="h-full flex-1 bg-transparent px-8 text-white placeholder-gray-500 outline-none"
                    value="<%= search %>"
                />

                <div class="relative h-full w-32 shrink-0">
                    <div class="absolute inset-0 bg-[#1B3563]" style="clip-path: polygon(5% 0%, 60% 0%, 40% 50%, 35% 50%);"></div>
                    <div class="absolute inset-0 bg-[#4BA3E3]/50" style="clip-path: polygon(55% 15%, 35% 50%, 60% 100%, 6% 100%);"></div>
                    <button onclick="handleSearch()"
                        class="absolute inset-0 flex items-center justify-end bg-gradient-to-r from-[#3fa9f5] to-[#1c92d2] text-white hover:brightness-110 transition-all"
                        style="clip-path: polygon(35% 50%, 60% 0%, 100% 0%, 100% 100%, 60% 100%);">
                        <i class="fa-solid fa-magnifying-glass text-2xl mr-8"></i>
                    </button>
                </div>
            </div>

            <!-- Button -->
            <button class="text-[white] text-[20px] flex justify-center items-center w-[132px] h-[50px] border border-[#4BA3E3]/50 rounded-[11px] bg-transparent gap-3">
                <i class="fi fi-br-bars-filter mt-2"></i>
                เรียง</button>

            <!-- Add/Delete Product Button -->
            <div class="flex flex-col gap-3 items-end">
                <button data-modal-target="add-product-modal" data-modal-toggle="add-product-modal"
                    class="text-[white] text-[20px] flex justify-center items-center w-[132px] h-[50px] rounded-[11px] bg-[#E2A829] gap-3">
                    <i class="fa-solid fa-plus" style="color: rgb(255, 255, 255);"></i>
                    เพิ่มสินค้า
                </button>
                <button id="bulkDeleteBtn" type="button" 
                        class="hidden text-[white] text-[20px] flex justify-center items-center w-[160px] h-[50px] rounded-[11px] bg-[#FF0000] gap-3 hover:bg-[#CC0000] transition-colors cursor-pointer">
                        <i class="fas fa-trash text-white"></i>
                        ลบทั้งหมด
                </button>
            </div>
        </div>

    </div>

    <!-- Product Table -->
    <div id="tableContainer" class="relative z-10 transition-transform duration-300">

        <div class="rounded-2xl overflow-hidden ml-[12%] mt-[26%]" style="width: 1147px;">
            <table class="w-full table-fixed  shadow-2xl rounded-2xl border border-[#4BA3E3]/20 border-separate border-spacing-0">
                    <thead class="bg-[#1B3563] text-white">
                        <tr>
                            <th class="py-4 px-5 text-left" style="width: 55px;">
                                <input type="checkbox" id="checkAll" class="custom-check" />
                            </th>
                            <th class="p-4 w-[350px] text-left text-[18px] font-medium">ชื่อสินค้า</th>
                            <th class="p-4 w-[150px] text-left text-[18px] font-medium">แบรนด์</th>
                            <th class="p-4 w-[150px] text-left text-[18px] font-medium">รหัสสินค้า</th>
                            <th class="p-4 w-[120px] text-left text-[18px] font-medium">ประเภท</th>
                            <th class="p-4 w-[120px] text-left text-[18px] font-medium">จำนวน</th>
                            <th class="p-4 text-left text-[18px] font-medium">จัดการสินค้า</th>
                        </tr>
                    </thead>
                    <tbody class="text-sm">
                        <tr class="border-t border-white/5 hover:bg-white/5">
                            <% if (products.length === 0) { %>
                        <tr>
                            <td colspan="4" class="text-center text-gray-400 py-28 text-xl border-none">
                                <i class="fas fa-inbox text-5xl mb-4 block text-gray-600"></i>
                                <span class="font-light">ไม่พบสินค้าที่คุณค้นหา</span>
                            </td>
                        </tr>
                    <% } else { %>
                        <% products.forEach((prod) => { %>
                            <tr class="sup-row border-t border-[#2a3a6e]/60 hover:bg-[#1e2b50]/50 transition-colors">
                                <td class="py-4 px-5 border-t border-[#4BA3E3]/20">
                                    <input type="checkbox" name="selected" value="<%= prod.prod_id %>" class="row-check custom-check" />
                                </td>
                                <td class="py-4 px-4 border-t border-[#4BA3E3]/20">
                                    <span class="text-white text-[16px]"><%= prod.prod_name %></span>
                                </td>
                                <td class="py-4 px-4 border-t border-[#4BA3E3]/20">
                                    <span class="text-white text-[16px]"><%= prod.brand %></span>
                                </td>
                                <td class="py-4 px-4 border-t border-[#4BA3E3]/20">
                                    <span class="text-white text-[16px]"><%= prod.prod_code %></span>
                                </td>
                                <td class="py-4 px-4 border-t border-[#4BA3E3]/20">
                                    <span class="text-white text-[16px]"><%= prod.prod_type %></span>
                                </td>
                                <td class="py-4 px-4 border-t border-[#4BA3E3]/20">
                                    <span class="text-white text-[16px]"><%= prod.amount %></span>
                                </td>
                                <td class="py-4 px-4 border-t border-[#4BA3E3]/20">
                                    <div class="flex gap-4">
                                        <button type="button" 
                                            onclick="openEditModal(this)"
                                            data-id="<%= prod.prod_id %>"
                                            data-code="<%= prod.prod_code %>"
                                            data-name="<%= prod.prod_name %>"
                                            data-brand="<%= prod.brand %>"
                                            data-type="<%= prod.prod_type %>"
                                            data-desc="<%= prod.description %>"
                                            data-img="<%= prod.prod_img %>"
                                            class="bg-[#4BA3E3] hover:bg-[#2C8BD0] text-white px-4 py-2 rounded-lg font-normal text-[14px] transition-colors shadow flex items-center gap-2">
                                            <i class="fas fa-pen-to-square text-s"></i> แก้ไข
                                        </button>
                                        <button onclick="confirmDelete(<%= prod.prod_id %>, `<%= prod.prod_name %>`, `<%= prod.brand %>`, `<%= prod.prod_code %>`, `<%= prod.prod_type %>`)"
                                            class="bg-[#FF0000] hover:bg-[#DC2626] text-white px-4 py-2 rounded-lg font-normal text-[14px] transition-colors shadow flex items-center gap-2">
                                            <i class="fas fa-trash text-xs"></i> ลบ
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>

                        <% for (let i = products.length; i < limit; i++) { %>
                            <tr>
                                <td class="py-4 px-5 border-t border-[#4BA3E3]/20">&nbsp;</td>
                                <td class="py-4 px-4 border-t border-[#4BA3E3]/20">&nbsp;</td>
                                <td class="py-4 px-4 border-t border-[#4BA3E3]/20">&nbsp;</td>
                                <td class="py-4 px-4 border-t border-[#4BA3E3]/20">&nbsp;</td>
                            </tr>
                        <% } %>
                    <% } %>
                        </tr>
                    </tbody>
                </table>

                <!-- Pagination -->
                <div class="flex items-center justify-between py-4 text-white text-[14px]" style="width: 1147px;">

                    <!-- Left -->
                    <div class="flex items-center gap-3">
                        <span class="text-gray-400">จำนวนแถวต่อ 1 หน้า</span>
                        <select id="limitSelect" onchange="changeLimit(this.value)"
                                class="bg-[#1a2342] border border-[#4BA3E3]/40 text-white rounded-md
                                    pl-2 py-1 text-[14px] focus:outline-none cursor-pointer">
                            <option value="5"  <%= limit===5  ? 'selected':'' %>>5</option>
                            <option value="10" <%= limit===10 ? 'selected':'' %>>10</option>
                            <option value="20" <%= limit===20 ? 'selected':'' %>>20</option>
                        </select>
                    </div>

                    <!-- Right -->
                    <div class="flex items-center gap-0.5">

                        <a href="/product_management?page=1&limit=<%= limit %>&search=<%= search %>&sort=<%= sort %>"
                        class="w-8 h-8 flex items-center justify-center <%= currentPage <= 1 ? 'text-slate-600 pointer-events-none' : 'text-gray-400 hover:text-white' %>">
                            <i class="fas fa-angles-left text-xs"></i>
                        </a>

                        <a href="/product_management?page=<%= Math.max(1, currentPage-1) %>&limit=<%= limit %>&search=<%= search %>&sort=<%= sort %>"
                        class="w-8 h-8 flex items-center justify-center <%= currentPage <= 1 ? 'text-slate-600 pointer-events-none' : 'text-gray-400 hover:text-white' %>">
                            <i class="fas fa-chevron-left text-xs"></i>
                        </a>

                        <% if (totalPages <= 7) { %>
                            <% for (let p = 1; p <= totalPages; p++) { %>
                                <a href="/product_management?page=<%= p %>&limit=<%= limit %>&search=<%= search %>&sort=<%= sort %>"
                                class="w-8 h-8 flex items-center justify-center text-[14px] font-medium rounded-md
                                        <%= p === currentPage ? 'border border-[#4BA3E3] text-white bg-[#4BA3E3]/10' : 'text-gray-400 hover:text-white' %>">
                                    <%= p %>
                                </a>
                            <% } %>
                        <% } else { %>
                            <% if (currentPage > 3) { %>
                                <a href="/product_management?page=1&limit=<%= limit %>&search=<%= search %>&sort=<%= sort %>" class="w-8 h-8 flex items-center justify-center text-gray-400 hover:text-white">1</a>
                                <span class="w-8 h-8 flex items-center justify-center text-gray-500">...</span>
                            <% } %>

                            <% 
                                let start = Math.max(1, currentPage - 2);
                                let end = Math.min(totalPages, currentPage + 2);
                                if (currentPage <= 3) end = Math.min(totalPages, 5);
                                if (currentPage >= totalPages - 2) start = Math.max(1, totalPages - 4);
                            %>
                            <% for (let p = start; p <= end; p++) { %>
                                <a href="/product_management?page=<%= p %>&limit=<%= limit %>&search=<%= search %>&sort=<%= sort %>"
                                class="w-8 h-8 flex items-center justify-center text-[14px] font-medium rounded-md
                                        <%= p === currentPage ? 'border border-[#4BA3E3] text-white bg-[#4BA3E3]/10' : 'text-gray-400 hover:text-white' %>">
                                    <%= p %>
                                </a>
                            <% } %>

                            <% if (currentPage < totalPages - 2) { %>
                                <span class="w-8 h-8 flex items-center justify-center text-gray-500">...</span>
                                <a href="/product_management?page=<%= totalPages %>&limit=<%= limit %>&search=<%= search %>&sort=<%= sort %>" class="w-8 h-8 flex items-center justify-center text-gray-400 hover:text-white"><%= totalPages %></a>
                            <% } %>
                        <% } %>

                        <a href="/product_management?page=<%= Math.min(totalPages, currentPage+1) %>&limit=<%= limit %>&search=<%= search %>&sort=<%= sort %>"
                        class="w-8 h-8 flex items-center justify-center <%= currentPage >= totalPages ? 'text-slate-600 pointer-events-none' : 'text-gray-400 hover:text-white' %>">
                            <i class="fas fa-chevron-right text-xs"></i>
                        </a>

                        <a href="/product_management?page=<%= totalPages %>&limit=<%= limit %>&search=<%= search %>&sort=<%= sort %>"
                        class="w-8 h-8 flex items-center justify-center <%= currentPage >= totalPages ? 'text-slate-600 pointer-events-none' : 'text-gray-400 hover:text-white' %>">
                            <i class="fas fa-angles-right text-xs"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

<!-- Add Product Modal -->
    <div id="add-product-modal" tabindex="-1"
        class="hidden fixed inset-0 z-[100] flex items-center justify-center bg-black/50 backdrop-blur-sm">
        
        <form action="/product_management" method="POST" enctype="multipart/form-data"
            class="relative flex flex-col bg-white rounded-2xl shadow-2xl w-[850px] p-10">
            
            <button type="button" data-modal-hide="add-product-modal" class="absolute top-6 right-6 text-gray-400 hover:text-gray-700 transition-colors">
                <i class="fa-solid fa-xmark text-3xl"></i>
            </button>

            <div class="mb-8 pl-2">
                <p class="text-[16px] font-normal text-[#9E9E9E]">แก้ไขข้อมูล</p>
                <h1 class="text-[36px] font-semibold text-[#1B3563] leading-none mt-1">เพิ่มสินค้า</h1>
            </div>

            <div class="flex gap-10">
                
                <div class="w-[40%] flex flex-col">
                    <div class="relative cursor-pointer group w-full h-[260px] border border-gray-200 bg-white flex items-center justify-center overflow-hidden" 
                        onclick="document.getElementById('add_imageInput').click()">
                        <img id="add_imgPreview" class="w-full h-full object-contain group-hover:opacity-40 transition-opacity" 
                            src="/images/products_img/no-product-image.jpeg" alt="Product Image">
                        <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity bg-[#1B3563]/20">
                            <i class="fa-solid fa-camera text-white text-4xl drop-shadow-md"></i>
                        </div>
                    </div>
                    <input type="file" id="add_imageInput" name="product_img" accept="image/*" class="hidden" onchange="previewAddImage(event)">
                </div>

                <div class="w-[60%] flex flex-col gap-6 pt-1">
                    
                    <div class="flex flex-col">
                        <label for="prod_name" class="text-[16px] text-[#9E9E9E] mb-1">ชื่อสินค้า</label>
                        <input type="text" id="prod_name" name="prod_name" required 
                            class="bg-[#F8F9FA] border-b-2 border-[#1B3563] h-[45px] outline-none px-3 w-full text-[#1B3563] text-[18px]">
                    </div>
                    
                    <div class="flex gap-6">
                        <div class="flex flex-col w-1/2">
                            <label for="prod_code" class="text-[16px] text-[#9E9E9E] mb-1">รหัสสินค้า</label>
                            <input type="text" id="prod_code" name="prod_code" required 
                                class="bg-[#F8F9FA] border-b-2 border-[#1B3563] h-[45px] outline-none px-3 w-full text-[#1B3563] text-[18px]">
                        </div>
                        <div class="flex flex-col w-1/2">
                            <label for="brand" class="text-[16px] text-[#9E9E9E] mb-1">แบรนด์</label>
                            <input type="text" id="brand" name="brand" required 
                                class="bg-[#F8F9FA] border-b-2 border-[#1B3563] h-[45px] outline-none px-3 w-full text-[#1B3563] text-[18px]">
                        </div>
                    </div>

                    <div class="flex flex-col relative">
                        <label for="prod_type" class="text-[16px] text-[#9E9E9E] mb-1">ประเภท</label>
                        <select id="prod_type" name="prod_type" required 
                                class="appearance-none bg-[#F8F9FA] border-b-2 border-[#1B3563] h-[45px] outline-none px-3 w-full text-[#1B3563] text-[18px] cursor-pointer">
                                    <option value="CPU">CPU</option>
                                    <option value="GPU">GPU</option>
                                    <option value="RAM">RAM</option>
                                    <option value="Mainboard">Mainboard</option>
                                    <option value="HDD">HDD</option>
                                    <option value="SSD">SSD</option>
                                    <option value="Case">Case</option>
                                    <option value="PowerSupply">PowerSupply</option>
                                    <option value="0CPUCooler9">CPUCooler</option>
                                    <option value="Monitor">Monitor</option>
                                    <option value="Other">Other</option>
                            </select>
                        <i class="fa-solid fa-caret-down absolute right-3 bottom-[12px] text-[#1B3563] pointer-events-none"></i>
                    </div>

                    <div class="flex flex-col">
                        <label for="description" class="text-[16px] text-[#9E9E9E] mb-1">คำอธิบาย</label>
                        <textarea name="description" id="description" class="bg-[#F8F9FA] border-b-2 border-[#1B3563] h-[45px] outline-none px-3 w-full text-[#1B3563] text-[18px]"></textarea>
                    </div>

                </div>
            </div>

            <div class="w-[100%] flex justify-end gap-4 mt-8">
                <button type="submit" 
                        class="px-[36px] py-[12px] bg-[#223961] hover:bg-[#15243E] transition-colors rounded-lg text-white font-medium text-[18px]">
                    ยืนยันการเพิ่ม
                </button>
                <button type="button" data-modal-hide="add-product-modal" onclick="closeModal('add-product-modal')"
                        class="px-[36px] py-[12px] bg-[#E53935] hover:bg-[#C62828] transition-colors rounded-lg text-white font-medium text-[18px]">
                    ยกเลิก
                </button>
            </div>
            
        </form>
    </div>

    <!-- Delete Product Modal -->
    <div id="deleteModal"
        class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/60">

        <div class="bg-white rounded-2xl shadow-2xl w-[400px] overflow-hidden">

            <!-- Content -->
            <div class="flex flex-col items-center pt-10 pb-8 px-8">
                <div class="w-[105px] mb-2">
                    <img src="/images/crisis.png" alt="">
                </div>

                <p class="text-[22px] text-center font-normal text-gray-800">
                    คุณต้องการลบ
                </p>
                <p class="text-[22px] text-center font-normal text-gray-800">
                    รายการสินค้าหรือไม่
                </p>
            </div>

            <!-- Button -->
            <div class="flex w-full">
                <form id="deleteForm" method="POST" class="w-1/2">
                    <input type="hidden" name="deleteIds" id="deleteIdsInput" value="">
                    <button type="submit"
                            class="w-full py-5 bg-[#0E1324] text-white text-[20px] font-semibold
                                hover:bg-[#1A2240] transition-colors">
                        ลบ
                    </button>
                </form>
                <button onclick="closeDeleteModal()"
                        class="w-1/2 py-5 bg-[#FF0000] text-white text-[20px] font-semibold
                            hover:bg-[#FF3333] transition-colors">
                    ยกเลิก
                </button>
            </div>
        </div>
    </div>



<!-- Edit Product Modal -->
    <div id="edit-product-modal" tabindex="-1"
        class="hidden fixed inset-0 z-[100] flex items-center justify-center bg-black/50 backdrop-blur-sm">
        
        <form id="editForm" method="POST" enctype="multipart/form-data"
            class="relative flex flex-col bg-white rounded-2xl shadow-2xl w-[850px] p-10">
            
            <button type="button" onclick="closeEditModal()" class="absolute top-6 right-6 text-gray-400 hover:text-gray-700 transition-colors">
                <i class="fa-solid fa-xmark text-3xl"></i>
            </button>

            <div class="mb-8 pl-2">
                <p class="text-[16px] font-normal text-[#9E9E9E]">แก้ไขข้อมูล</p>
                <h1 class="text-[36px] font-semibold text-[#1B3563] leading-none mt-1">แก้ไขสินค้า</h1>
            </div>

            <div class="flex gap-10">
                
                <div class="w-[40%] flex flex-col">
                    <div class="relative cursor-pointer group w-full h-[260px] border border-gray-200 bg-white flex items-center justify-center overflow-hidden" 
                        onclick="document.getElementById('edit_imageInput').click()">
                        <img id="edit_imgPreview" class="w-full h-full object-contain group-hover:opacity-40 transition-opacity" 
                            src="/images/products_img/no-product-image.jpeg" alt="Product Image">
                        <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity bg-[#1B3563]/20">
                            <i class="fa-solid fa-camera text-white text-4xl drop-shadow-md"></i>
                        </div>
                    </div>
                    <input type="file" id="edit_imageInput" name="product_img" accept="image/*" class="hidden" onchange="previewEditImage(event)">
                </div>

                <div class="w-[60%] flex flex-col gap-6 pt-1">
                    
                    <div class="flex flex-col">
                        <label for="edit_prod_name" class="text-[16px] text-[#9E9E9E] mb-1">ชื่อสินค้า</label>
                        <input type="text" id="edit_prod_name" name="prod_name" required 
                            class="bg-[#F8F9FA] border-b-2 border-[#1B3563] h-[45px] outline-none px-3 w-full text-[#1B3563] text-[18px]">
                    </div>
                    
                    <div class="flex gap-6">
                        <div class="flex flex-col w-1/2">
                            <label for="edit_prod_code" class="text-[16px] text-[#9E9E9E] mb-1">รหัสสินค้า</label>
                            <input type="text" id="edit_prod_code" name="prod_code" required 
                                class="bg-[#F8F9FA] border-b-2 border-[#1B3563] h-[45px] outline-none px-3 w-full text-[#1B3563] text-[18px]">
                        </div>
                        <div class="flex flex-col w-1/2">
                            <label for="edit_brand" class="text-[16px] text-[#9E9E9E] mb-1">แบรนด์</label>
                            <input type="text" id="edit_brand" name="brand" required 
                                class="bg-[#F8F9FA] border-b-2 border-[#1B3563] h-[45px] outline-none px-3 w-full text-[#1B3563] text-[18px]">
                        </div>
                    </div>

                    <div class="flex flex-col relative">
                        <label for="edit_prod_type" class="text-[16px] text-[#9E9E9E] mb-1">ประเภท</label>
                        <select id="edit_prod_type" name="prod_type" required 
                                class="appearance-none bg-[#F8F9FA] border-b-2 border-[#1B3563] h-[45px] outline-none px-3 w-full text-[#1B3563] text-[18px] cursor-pointer">
                                    <option value="CPU">CPU</option>
                                    <option value="GPU">GPU</option>
                                    <option value="RAM">RAM</option>
                                    <option value="Mainboard">Mainboard</option>
                                    <option value="HDD">HDD</option>
                                    <option value="SSD">SSD</option>
                                    <option value="Case">Case</option>
                                    <option value="PowerSupply">PowerSupply</option>
                                    <option value="CPUCooler">CPUCooler</option>
                                    <option value="Monitor">Monitor</option>
                                    <option value="Other">Other</option>
                            </select>
                        <i class="fa-solid fa-caret-down absolute right-3 bottom-[12px] text-[#1B3563] pointer-events-none"></i>
                    </div>

                    <div class="flex flex-col">
                        <label for="edit_description" class="text-[16px] text-[#9E9E9E] mb-1">คำอธิบาย</label>
                        <textarea name="description" id="edit_description" rows="2" 
                            class="bg-[#F8F9FA] border-b-2 border-[#1B3563] outline-none p-3 w-full text-[#1B3563] text-[18px] resize-none custom-scroll"></textarea>
                    </div>

                </div>
            </div>

            <div class="w-[100%] flex justify-end gap-4 mt-8">
                <button type="submit" 
                        class="px-[36px] py-[12px] bg-[#223961] hover:bg-[#15243E] transition-colors rounded-lg text-white font-medium text-[18px]">
                    ยืนยันการแก้ไข
                </button>
                <button type="button" onclick="closeEditModal()"
                        class="px-[36px] py-[12px] bg-[#E53935] hover:bg-[#C62828] transition-colors rounded-lg text-white font-medium text-[18px]">
                    ยกเลิก
                </button>
            </div>
            
        </form>
    </div>


    <script>
        const CURRENT_SORT = '<%= sort %>';
    </script>

    <script src="/management/product.js"></script>
    <script src="/js/currentdate.js"></script>
</body>
</html>