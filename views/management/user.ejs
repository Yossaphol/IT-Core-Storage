<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>User Management</title>
    <style>
        /* เปลี่ยนสีพื้นหลัง CSS ให้ตรงกับ Three.js */
        body { margin: 0; overflow: auto; background-color: #0E1324; }
        canvas { display: block; }

        .custom-check {
            appearance: none; -webkit-appearance: none;
            width: 1.3rem; height: 1.3rem;
            border: 2px solid #6b7280; border-radius: 0.3rem;
            background-color: transparent; cursor: pointer;
            position: relative; transition: all 0.15s ease;
        }
        .custom-check:checked { background-color: #22c55e; border-color: #22c55e; }
        .custom-check:checked::after {
            font-family: "Font Awesome 6 Free";
            font-weight: 900;
            content: '\f00c'; position: absolute; top: 50%; left: 50%;
            transform: translate(-50%, -50%); color: white; font-size: 0.8rem; font-weight: bold;
        }

        .custom-scroll::-webkit-scrollbar { width: 5px; }
        .custom-scroll::-webkit-scrollbar-track { background: transparent; }
        .custom-scroll::-webkit-scrollbar-thumb { background: #2a3a6e; border-radius: 3px; }

    </style>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="https://cdn-uicons.flaticon.com/uicons-bold-rounded/css/uicons-bold-rounded.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Prompt:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&family=SN+Pro:ital,wght@0,200..900;1,200..900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/font.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/flowbite@latest/dist/flowbite.min.js"></script>
    <script src="management/user.js"></script>
    
</head>

<body>
    
    <div class="relative z-20 pointer-events-none">
        <%- include('../partials/header_with_path', { path1 : "การจัดการผู้ใช้", url_1 : "/user_management"}) %>
    </div>
    <div class="absolute top-[17%] left-[12%]">
        <p class="text-white text-[40px]">การจัดการผู้ใช้</p>
        <p class="text-gray-400 text-[15px] font-light">เพิ่ม / แก้ไข / ลบ / กำหนดสิทธิ์</p>
        <p class="text-gray-400 text-[15px] font-light">รวมถึงควบคุมการเข้าถึงฟังก์ชันต่าง ๆ ของผู้ใช้งาน ได้ที่นี่</p>
        
    </div>

    <img class="fixed w-70 right-10 top-0" src="/images/chklist.png" alt="">

    <div class="absolute top-[37%] inset-x-[12%] right-[10%] flex items-start justify-between">
        
        <div class="flex h-14 items-center">
            <p class="text-white text-[20px]">ผู้ใช้ทั้งหมด <%= total %></p>
        </div>
        
        <div class="flex items-start gap-5">

            <!-- Search Bar -->
            <div class="relative flex h-14 w-[500px] items-center overflow-hidden rounded-full border border-[#4BA3E3]/20 bg-transparent">
                <input type="text" id="searchInput" placeholder="ค้นหา ชื่อ-นามสกุล พนักงาน" 
                    class="h-full flex-1 bg-transparent px-8 text-white placeholder-gray-500 outline-none"
                    value="<%= search %>"
                />

                <div class="relative h-full w-32 shrink-0">
                    <div class="absolute inset-0 bg-[#1B3563]" style="clip-path: polygon(5% 0%, 60% 0%, 40% 50%, 35% 50%);"></div>
                    <div class="absolute inset-0 bg-[#4BA3E3]/50" style="clip-path: polygon(55% 15%, 35% 50%, 60% 100%, 6% 100%);"></div>
                    <button onclick="handleSearch()"
                        class="absolute inset-0 flex items-center justify-end bg-gradient-to-r from-[#3fa9f5] to-[#1c92d2] text-white hover:brightness-110 transition-all"
                        style="clip-path: polygon(35% 50%, 60% 0%, 100% 0%, 100% 100%, 60% 100%);">
                        <i class="fa-solid fa-magnifying-glass text-2xl mr-8"></i>
                    </button>
                </div>
            </div>

            <!-- Sort Button-->
             <div class="relative">
                <button id="dropdownSortButton" data-dropdown-toggle="dropdownSort"
                    class="text-[white] text-[20px] flex justify-center items-center w-[132px] h-[50px] border border-[#4BA3E3]/50 rounded-[11px] bg-transparent gap-3">
                    <i class="fi fi-br-bars-filter mt-2"></i>
                    กรอง
                </button>
                <div id="dropdownSort" class="z-50 hidden bg-white divide-y divide-gray-100 rounded-lg shadow w-40 border border-[#4BA3E3]/30">
                    <ul class="py-2 text-sm text-[#1B3563]" aria-labelledby="dropdownSortButton">
                        <li>
                            <button onclick="handleSort('DESC')" class="block w-full text-left px-4 py-3 hover:bg-[#4BA3E3]/20 transition-colors">
                                <i class="fa-solid fa-arrows-up-down mr-2.5"></i> ใหม่สุด
                            </button>
                        </li>
                        <li>
                            <button onclick="handleSort('ASC')" class="block w-full text-left px-4 py-3 hover:bg-[#4BA3E3]/20 transition-colors">
                                <i class="fa-solid fa-arrows-up-down mr-2.5"></i> เก่าสุด
                            </button>
                        </li>
                        <hr class="border-[#4BA3E3]/20">
                        <li>
                            <button onclick="handleSort('NAME_ASC')" class="block w-full text-left px-3 py-2 hover:bg-[#4BA3E3]/20 transition-colors font-normal">
                                <i class="fa-solid fa-sort-alpha-down mr-2"></i> ชื่อ ก-ฮ (A-Z)
                            </button>
                        </li>
                        <li>
                            <button onclick="handleSort('NAME_DESC')" class="block w-full text-left px-3 py-2 hover:bg-[#4BA3E3]/20 transition-colors font-normal">
                                <i class="fa-solid fa-sort-alpha-up mr-2"></i> ชื่อ ฮ-ก (Z-A)
                            </button>
                        </li>
                    </ul>
                </div>
            </div>
            
            <div class="flex flex-col gap-3 items-end w-[160px]">
                <button data-modal-target="add-user-modal" data-modal-toggle="add-user-modal"
                    class="text-[white] text-[20px] flex justify-center items-center w-[132px] h-[50px] rounded-[11px] bg-[#E2A829] gap-3">
                    <i class="fa-solid fa-plus" style="color: rgb(255, 255, 255);"></i>
                    เพิ่มผู้ใช้
                </button>
                <button id="bulkDeleteBtn" type="button" 
                        class="hidden text-[white] text-[20px] flex justify-center items-center w-[160px] h-[50px] rounded-[11px] bg-[#FF0000] gap-3 hover:bg-[#CC0000] transition-colors cursor-pointer">
                        <i class="fas fa-trash text-white"></i>
                        ลบทั้งหมด
                </button>
            </div>
        </div>

    </div>

    <!-- User Table -->
    <div id="tableContainer" class="relative z-10 transition-transform duration-300">

        <div class="rounded-2xl overflow-hidden ml-[12%] mt-[26%]" style="width: 1147px;">
            <table class="w-full table-fixed  shadow-2xl rounded-2xl border border-[#4BA3E3]/20 border-separate border-spacing-0">
                <thead>
                    <tr class="bg-[#1B3563] text-white">
                        <th class="py-4 px-5 text-left" style="width: 55px;">
                            <input type="checkbox" id="checkAll" class="custom-check" />
                        </th>
                        <th class="py-4 px-4 text-left text-[18px] font-medium" style="width: 380px;">ชื่อผู้ใช้งาน</th>
                        <th class="py-4 px-4 text-left text-[18px] font-medium">บทบาท</th>
                        <th class="py-4 px-4 text-left text-[18px] font-medium" style="width: 220px;">จัดการผู้ใช้</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (employees.length === 0) { %>
                        <tr>
                            <td colspan="4" class="text-center text-gray-400 py-28 text-xl border-none">
                                <i class="fas fa-inbox text-5xl mb-4 block text-gray-600"></i>
                                <span class="font-light">ไม่พบรายชื่อผู้ใช้ที่คุณค้นหา</span>
                            </td>
                        </tr>
                    <% } else { %>
                        <% employees.forEach((emp) => { %>
                            <tr class="sup-row border-t border-[#2a3a6e]/60 hover:bg-[#1e2b50]/50 transition-colors">
                                <td class="py-4 px-5 border-t border-[#4BA3E3]/20">
                                    <input type="checkbox" name="selected" value="<%= emp.emp_id %>" class="row-check custom-check" />
                                </td>
                                <td class="py-4 px-4 border-t border-[#4BA3E3]/20">
                                    <span class="text-white text-[16px]"><%= emp.emp_firstname %> <%= emp.emp_lastname %></span>
                                </td>
                                <td class="py-4 px-4 border-t border-[#4BA3E3]/20">
                                    <span class="text-white text-[16px]"><%= emp.emp_role %></span>
                                </td>
                                <td class="py-4 px-4 border-t border-[#4BA3E3]/20">
                                    <div class="flex gap-4">
                                        <button onclick="openEditModal('<%= emp.emp_id %>', `<%= emp.emp_firstname %>`,`<%= emp.emp_lastname %>`, `<%= emp.username %>`, `<%= emp.emp_role %>`, `<%= emp.emp_img %>`)"
                                            class="bg-[#4BA3E3] hover:bg-[#2C8BD0] text-white px-4 py-2 rounded-lg font-normal text-[14px] transition-colors shadow flex items-center gap-2">
                                            <i class="fas fa-pen-to-square text-s"></i> แก้ไข
                                        </button>
                                        <button onclick="confirmDelete(<%= emp.emp_id %>, '<%= emp.emp_firstname %>')"
                                            class="bg-[#FF0000] hover:bg-[#DC2626] text-white px-4 py-2 rounded-lg font-normal text-[14px] transition-colors shadow flex items-center gap-2">
                                            <i class="fas fa-trash text-xs"></i> ลบ
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>

                        <% for (let i = employees.length; i < limit; i++) { %>
                            <tr>
                                <td class="py-4 px-5 border-t border-[#4BA3E3]/20">&nbsp;</td>
                                <td class="py-4 px-4 border-t border-[#4BA3E3]/20">&nbsp;</td>
                                <td class="py-4 px-4 border-t border-[#4BA3E3]/20">&nbsp;</td>
                                <td class="py-4 px-4 border-t border-[#4BA3E3]/20">&nbsp;</td>
                            </tr>
                        <% } %>
                    <% } %>
                </tbody>
            </table>
            
            <!-- Pagination -->
            <div class="flex items-center justify-between py-4 text-white text-[14px]" style="width: 1147px;">

                <!-- Left -->
                <div class="flex items-center gap-3">
                    <span class="text-gray-400">จำนวนแถวต่อ 1 หน้า</span>
                    <select id="limitSelect" onchange="changeLimit(this.value)"
                            class="bg-[#1a2342] border border-[#4BA3E3]/40 text-white rounded-md
                                pl-2 py-1 text-[14px] focus:outline-none cursor-pointer">
                        <option value="5"  <%= limit===5  ? 'selected':'' %>>5</option>
                        <option value="10" <%= limit===10 ? 'selected':'' %>>10</option>
                        <option value="20" <%= limit===20 ? 'selected':'' %>>20</option>
                    </select>
                </div>

                <!-- Right -->
                <div class="flex items-center gap-0.5">

                    <a href="/user_management?page=1&limit=<%= limit %>&search=<%= search %>&sort=<%= sort %>"
                    class="w-8 h-8 flex items-center justify-center <%= currentPage <= 1 ? 'text-slate-600 pointer-events-none' : 'text-gray-400 hover:text-white' %>">
                        <i class="fas fa-angles-left text-xs"></i>
                    </a>

                    <a href="/user_management?page=<%= Math.max(1, currentPage-1) %>&limit=<%= limit %>&search=<%= search %>&sort=<%= sort %>"
                    class="w-8 h-8 flex items-center justify-center <%= currentPage <= 1 ? 'text-slate-600 pointer-events-none' : 'text-gray-400 hover:text-white' %>">
                        <i class="fas fa-chevron-left text-xs"></i>
                    </a>

                    <% if (totalPages <= 7) { %>
                        <% for (let p = 1; p <= totalPages; p++) { %>
                            <a href="/user_management?page=<%= p %>&limit=<%= limit %>&search=<%= search %>&sort=<%= sort %>"
                            class="w-8 h-8 flex items-center justify-center text-[14px] font-medium rounded-md
                                    <%= p === currentPage ? 'border border-[#4BA3E3] text-white bg-[#4BA3E3]/10' : 'text-gray-400 hover:text-white' %>">
                                <%= p %>
                            </a>
                        <% } %>
                    <% } else { %>
                        <% if (currentPage > 3) { %>
                            <a href="/user_management?page=1&limit=<%= limit %>&search=<%= search %>&sort=<%= sort %>" class="w-8 h-8 flex items-center justify-center text-gray-400 hover:text-white">1</a>
                            <span class="w-8 h-8 flex items-center justify-center text-gray-500">...</span>
                        <% } %>

                        <% 
                            let start = Math.max(1, currentPage - 2);
                            let end = Math.min(totalPages, currentPage + 2);
                            if (currentPage <= 3) end = Math.min(totalPages, 5);
                            if (currentPage >= totalPages - 2) start = Math.max(1, totalPages - 4);
                        %>
                        <% for (let p = start; p <= end; p++) { %>
                            <a href="/user_management?page=<%= p %>&limit=<%= limit %>&search=<%= search %>&sort=<%= sort %>"
                            class="w-8 h-8 flex items-center justify-center text-[14px] font-medium rounded-md
                                    <%= p === currentPage ? 'border border-[#4BA3E3] text-white bg-[#4BA3E3]/10' : 'text-gray-400 hover:text-white' %>">
                                <%= p %>
                            </a>
                        <% } %>

                        <% if (currentPage < totalPages - 2) { %>
                            <span class="w-8 h-8 flex items-center justify-center text-gray-500">...</span>
                            <a href="/user_management?page=<%= totalPages %>&limit=<%= limit %>&search=<%= search %>&sort=<%= sort %>" class="w-8 h-8 flex items-center justify-center text-gray-400 hover:text-white"><%= totalPages %></a>
                        <% } %>
                    <% } %>

                    <a href="/user_management?page=<%= Math.min(totalPages, currentPage+1) %>&limit=<%= limit %>&search=<%= search %>&sort=<%= sort %>"
                    class="w-8 h-8 flex items-center justify-center <%= currentPage >= totalPages ? 'text-slate-600 pointer-events-none' : 'text-gray-400 hover:text-white' %>">
                        <i class="fas fa-chevron-right text-xs"></i>
                    </a>

                    <a href="/user_management?page=<%= totalPages %>&limit=<%= limit %>&search=<%= search %>&sort=<%= sort %>"
                    class="w-8 h-8 flex items-center justify-center <%= currentPage >= totalPages ? 'text-slate-600 pointer-events-none' : 'text-gray-400 hover:text-white' %>">
                        <i class="fas fa-angles-right text-xs"></i>
                    </a>
                </div>
            </div>

        </div>
    </div>

    <!-- Delete Sup Modal -->
    <div id="deleteModal"
        class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/60">

        <div class="bg-white rounded-2xl shadow-2xl w-[400px] overflow-hidden">

            <!-- Content -->
            <div class="flex flex-col items-center pt-10 pb-8 px-8">
                <div class="w-[105px] mb-2">
                    <img src="/images/crisis.png" alt="">
                </div>

                <p class="text-[22px] text-center font-normal text-gray-800">
                    คุณต้องการลบรายชื่อ
                </p>
                <p class="text-[22px] text-center font-normal text-gray-800">
                    ผู้ใช้งานหรือไม่
                </p>
            </div>

            <!-- Button -->
            <div class="flex w-full">
                <form id="deleteForm" method="POST" class="w-1/2">
                    <input type="hidden" name="deleteIds" id="deleteIdsInput" value="">
                    <button type="submit"
                            class="w-full py-5 bg-[#0E1324] text-white text-[20px] font-semibold
                                hover:bg-[#1A2240] transition-colors">
                        ลบ
                    </button>
                </form>
                <button onclick="closeDeleteModal()"
                        class="w-1/2 py-5 bg-[#FF0000] text-white text-[20px] font-semibold
                            hover:bg-[#FF3333] transition-colors">
                    ยกเลิก
                </button>
            </div>
        </div>
    </div>
    

    <!-- Add User Modal -->
    <div id="add-user-modal" tabindex="-1"
        class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50">
        
        <form action="/user_management" method="POST" enctype="multipart/form-data"
            class="flex flex-col bg-white rounded-xl shadow-lg w-[750px] h-[610px] p-6">
            
            <!-- Header -->
            <div class="flex justify-between">
                <p class="text-md font-normal text-[#9E9E9E] ml-5 mt-3">เพิ่มข้อมูล</p>
                <button data-modal-hide="add-user-modal" class="mr-3">
                        <i class="fa-solid fa-xmark text-2xl" style="color: #9E9E9E;"></i>
                </button>
            </div>
            <h1 class="text-[36px] ml-5">เพิ่มผู้ใช้งาน</h1>

            <!-- Body -->
            <div class="flex gap-3 ml-5 mt-8">
                
                <!-- Upload Profile -->
                <div class="relative cursor-pointer group shrink-0" onclick="document.getElementById('add_imageInput').click()">
                    <img id="add_imgPreview" class="w-[260px] h-[260px] rounded-full object-cover group-hover:opacity-50 transition-opacity" src="/images/profile/user.png" alt="">
                    <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity bg-black/30 rounded-full w-[260px] h-[260px]">
                        <i class="fa-solid fa-camera text-white text-4xl"></i>
                    </div>
                </div>

                <input type="file" id="add_imageInput" name="emp_img" accept="image/*" class="hidden" onchange="previewAddImage(event)">

                <div class="flex flex-col w-[50%] ml-8">
                    
                    <span class="flex gap-3 mt-2">
                        <div>
                            <label for="firstname" class="text-[16px] text-[#9E9E9E]">ชื่อจริง</label>
                            <input type="text" id="emp_firstname" name="emp_firstname" required class="bg-[#F5F5F5] border-b-2 border-[#1B3563] h-[40px] outline-0 p-3 w-[100%] text-[#1B3563] mt-1">
                        </div>
                        <div>
                            <label for="lastname" class="text-[16px] text-[#9E9E9E] mt-2">นามสกุล</label>
                            <input type="text" id="emp_lastname" name="emp_lastname" required class="bg-[#F5F5F5] border-b-2 border-[#1B3563] h-[40px] outline-0 p-3 w-[100%] text-[#1B3563] mt-1">
                        </div>
                    </span>

                    <label for="username" class="text-[16px] text-[#9E9E9E] mt-2">ชื่อผู้ใช้</label>
                    <input type="text" id="username" name="username" required class="bg-[#F5F5F5] border-b-2 border-[#1B3563] h-[40px] outline-0 p-3 w-[100%] text-[#1B3563] mt-1">

                    <label for="password" class="text-[16px] text-[#9E9E9E] mt-2">รหัสผ่าน</label>
                    <input type="text" id="password" name="password" required class="bg-[#F5F5F5] border-b-2 border-[#1B3563] h-[40px] outline-0 p-3 w-[100%] text-[#1B3563] mt-1">
                
                    <!-- บทบาท -->
                    <div class="mt-2">
                        <label class="block text-[#9E9E9E] text-[16px]">บทบาท</label>

                        <!-- แสดง Tag บทบาทที่เลือกแล้ว -->
                        <div id="add_selectedRoles" class="flex flex-wrap gap-3 mb-4 mt-2">
                        <!-- Tag จะถูกเพิ่มที่นี่ด้วย JavaScript -->
                        </div>

                        <!-- Hidden inputs สำหรับส่งค่า roles ไปกับ form -->
                        <div id="add_hiddenInputs"></div>

                        <!-- ปุ่มเพิ่มบทบาท + Dropdown -->
                        <div class="relative inline-block">
                            <button
                                type="button"
                                id="add_addRoleBtn"
                                class="border-2 border-dashed border-sky-400 text-sky-500 
                                    px-6 py-2 rounded-full hover:bg-sky-50 
                                    transition-colors flex items-center gap-2 font-medium"
                            >
                                <i class="fa-solid fa-plus" style="color: sky-400;"></i>
                                เพิ่มบทบาท
                            </button>
                            <!-- Dropdown เลือกบทบาท -->
                            <div
                                id="add_roleDropdown"
                                class="hidden absolute left-0 top-full mt-2 bg-white border border-gray-200 
                                    rounded-xl shadow-xl z-10 overflow-hidden min-w-[200px]"
                            >
                                <button type="button" data-role="manager"
                                class="role-option w-full text-left px-5 py-3 hover:bg-purple-50 
                                        text-gray-700 transition-colors text-base font-medium 
                                        border-b border-gray-100">
                                ผู้จัดการ
                                </button>
                                <button type="button" data-role="system"
                                class="role-option w-full text-left px-5 py-3 hover:bg-red-50 
                                        text-gray-700 transition-colors text-base font-medium 
                                        border-b border-gray-100">
                                เจ้าหน้าที่ระบบ
                                </button>
                                <button type="button" data-role="warehouse"
                                class="role-option w-full text-left px-5 py-3 hover:bg-green-50 
                                        text-gray-700 transition-colors text-base font-medium">
                                เจ้าหน้าที่คลังสินค้า
                                </button>
                            </div>
                        </div>
                    </div>
                
                </div>
            </div>

            <!-- Button -->
            <div class="w-[100%] flex justify-end pt-5 gap-5 mt-auto mb-3 pr-3">
                <button type="submit" class="px-[32px] py-[12px] bg-[#1B3563] rounded-[8px] text-white">
                    ยืนยันการเพิ่ม
                </button>
                <button type="button" data-modal-hide="add-user-modal" class="px-[32px] py-[12px] bg-[#F00] rounded-[8px] text-white">
                    ยกเลิก
                </button>
            </div>
        </form>
    </div>

    <div id="edit-sup-modal" tabindex="-1" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50">
        <form id="editForm" method="POST" enctype="multipart/form-data" class="flex flex-col bg-white rounded-xl shadow-lg w-[750px] h-[610px] p-6">
            
            <div class="flex justify-between">
                <p class="text-md font-normal text-[#9E9E9E] ml-5 mt-3">แก้ไขข้อมูล</p>
                <button type="button" onclick="closeEditModal()" class="mr-3">
                    <i class="fa-solid fa-xmark text-2xl" style="color: #9E9E9E;"></i>
                </button>
            </div>
            <h1 class="text-[36px] ml-5">แก้ไขผู้ใช้งาน</h1>

            <div class="flex gap-3 ml-5 mt-8">
                
                <div class="relative cursor-pointer group shrink-0" onclick="document.getElementById('edit_imageInput').click()">
                    <img id="edit_imgPreview" class="w-[260px] h-[260px] rounded-full object-cover group-hover:opacity-50 transition-opacity" src="/images/user.png" alt="Profile Image">
                    <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity bg-black/30 rounded-full w-[260px] h-[260px]">
                        <i class="fa-solid fa-camera text-white text-4xl"></i>
                    </div>
                </div>
                
                <input type="file" id="edit_imageInput" name="emp_img" accept="image/png, image/jpeg, image/jpg" class="hidden" onchange="previewEditImage(event)">

                <div class="flex flex-col w-[50%] ml-8">
                    <span class="flex gap-3 mt-2">
                        <div>
                            <label for="edit_emp_firstname" class="text-[16px] text-[#9E9E9E]">ชื่อจริง</label>
                            <input type="text" id="edit_emp_firstname" name="emp_firstname" required class="bg-[#F5F5F5] border-b-2 border-[#1B3563] h-[40px] outline-0 p-3 w-[100%] text-[#1B3563] mt-1">
                        </div>
                        <div>
                            <label for="edit_emp_lastname" class="text-[16px] text-[#9E9E9E] mt-2">นามสกุล</label>
                            <input type="text" id="edit_emp_lastname" name="emp_lastname" required class="bg-[#F5F5F5] border-b-2 border-[#1B3563] h-[40px] outline-0 p-3 w-[100%] text-[#1B3563] mt-1">
                        </div>
                    </span>

                    <label for="edit_username" class="text-[16px] text-[#9E9E9E] mt-2">ชื่อผู้ใช้</label>
                    <input type="text" id="edit_username" name="username" required class="bg-[#F5F5F5] border-b-2 border-[#1B3563] h-[40px] outline-0 p-3 w-[100%] text-[#1B3563] mt-1">
                
                    <div class="mt-2">
                        <label class="block text-[#9E9E9E] text-[16px]">บทบาท</label>
                        <div id="edit_selectedRoles" class="flex flex-wrap gap-3 mb-4 mt-2"></div>
                        <div id="edit_hiddenInputs"></div>
                        <div class="relative inline-block">
                            <button type="button" id="edit_addRoleBtn" class="border-2 border-dashed border-sky-400 text-sky-500 px-6 py-2 rounded-full hover:bg-sky-50 transition-colors flex items-center gap-2 font-medium">
                                <i class="fa-solid fa-plus" style="color: sky-400;"></i> เพิ่มบทบาท
                            </button>
                            <div id="edit_roleDropdown" class="hidden absolute left-0 top-full mt-2 bg-white border border-gray-200 rounded-xl shadow-xl z-10 overflow-hidden min-w-[200px]">
                                <button type="button" data-role="manager" class="role-option w-full text-left px-5 py-3 hover:bg-purple-50 text-gray-700 transition-colors text-base font-medium border-b border-gray-100">ผู้จัดการ</button>
                                <button type="button" data-role="sysadmin" class="role-option w-full text-left px-5 py-3 hover:bg-red-50 text-gray-700 transition-colors text-base font-medium border-b border-gray-100">เจ้าหน้าที่ระบบ</button>
                                <button type="button" data-role="warehouse" class="role-option w-full text-left px-5 py-3 hover:bg-green-50 text-gray-700 transition-colors text-base font-medium">เจ้าหน้าที่คลังสินค้า</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="w-[100%] flex justify-end pt-5 gap-5 mt-auto mb-3 pr-3">
                <button type="submit" class="px-[32px] py-[12px] bg-[#1B3563] rounded-[8px] text-white">ยืนยันการแก้ไข</button>
                <button type="button" onclick="closeEditModal()" class="px-[32px] py-[12px] bg-[#F00] rounded-[8px] text-white">ยกเลิก</button>
            </div>
        </form>
    </div>

    <!-- Animation -->
