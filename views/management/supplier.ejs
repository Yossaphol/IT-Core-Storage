<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Supplier Management</title>
    <style>
        /* เปลี่ยนสีพื้นหลัง CSS ให้ตรงกับ Three.js */
        body { margin: 0; overflow-y: auto; background-color: #0E1324; }
        canvas { display: block; }
    </style>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="https://cdn-uicons.flaticon.com/uicons-bold-rounded/css/uicons-bold-rounded.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Prompt:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&family=SN+Pro:ital,wght@0,200..900;1,200..900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/font.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/flowbite@latest/dist/flowbite.min.js"></script>
</head>
<body>
    
    <div class="relative z-20 pointer-events-none">
        <%- include('../partials/header_with_path', { path1 : "การจัดการผู้จำหน่ายสินค้า", url_1 : "/supplier_management"}) %>
    </div>
    <div class="relative px-[12%] pt-[120px] pb-20">
        <p class="text-white text-[40px]">การจัดการผู้จำหน่ายสินค้า</p>
        <p class="text-gray-400 text-[15px] font-light">เพิ่ม / แก้ไข / ลบ ข้อมูล Supplier ได้ที่นี่</p>        
    </div>

    <img class="fixed w-70 right-10" src="/images/chklist.png" alt="">

    <div class="absolute top-[37%] inset-x-[12%] right-[10%] flex items-center">
        <p class="text-white text-[20px]">ผู้จำหน่ายทั้งหมด <%= total %></p>
        <p id="amount_user"></p>
                
        <div class="flex items-center ml-auto gap-5">

            <!-- Search Bar -->
            <div class="relative flex h-14 w-[500px] items-center overflow-hidden rounded-full border border-[#4BA3E3]/20 bg-transparent">
                <input type="text" placeholder="ค้นหา ชื่อ" 
                    class="h-full flex-1 bg-transparent px-8 text-white placeholder-gray-500 outline-none"
                />

                <div class="relative h-full w-32 shrink-0">
                    <div class="absolute inset-0 bg-[#1B3563]" style="clip-path: polygon(5% 0%, 60% 0%, 40% 50%, 35% 50%);"></div>
                    <div class="absolute inset-0 bg-[#4BA3E3]/50" style="clip-path: polygon(55% 15%, 35% 50%, 60% 100%, 6% 100%);"></div>
                    <button 
                        class="absolute inset-0 flex items-center justify-end bg-gradient-to-r from-[#3fa9f5] to-[#1c92d2] text-white hover:brightness-110 transition-all"
                        style="clip-path: polygon(35% 50%, 60% 0%, 100% 0%, 100% 100%, 60% 100%);">
                        <i class="fa-solid fa-magnifying-glass text-2xl mr-8"></i>
                    </button>
                </div>
            </div>

            <!-- Button -->
            <button class="text-[white] text-[20px] flex justify-center items-center w-[132px] h-[50px] border border-[#4BA3E3]/50 rounded-[11px] bg-transparent gap-3">
                <i class="fi fi-br-bars-filter mt-2"></i>
                กรอง</button>
            <button data-modal-target="add-sup-modal" data-modal-toggle="add-sup-modal"
                class="text-[white] text-[20px] flex justify-center items-center w-[165px] h-[50px] rounded-[11px] bg-[#E2A829] gap-3">
                <i class="fa-solid fa-plus" style="color: rgb(255, 255, 255);"></i>
                เพิ่มผู้จำหน่าย
            </button>
        </div>

    </div>

    <!-- User Table -->
    
    <!-- ===== ตาราง ===== -->
<div class="relative z-10">

    <!-- ✅ ไม่มี height ตายตัว / ไม่มี overflow-y ในตาราง -->
    <div class="rounded-2xl overflow-hidden ml-[12%] mt-[8%]" style="width: 1147px;">
        <table class="w-full table-fixed bg-[#1a2342] shadow-2xl rounded-2xl">
            <thead>
                <tr class="bg-[#2a3a6e]/90 text-white">
                    <th class="py-4 px-5 text-left" style="width: 55px;">
                        <input type="checkbox" id="checkAll" class="custom-check" />
                    </th>
                    <th class="py-4 px-4 text-left text-[16px] font-medium">บริษัทผู้จำหน่าย</th>
                    <th class="py-4 px-4 text-left text-[16px] font-medium" style="width: 280px;">เบอร์ติดต่อ</th>
                    <th class="py-4 px-4 text-left text-[16px] font-medium" style="width: 220px;">จัดการผู้ใช้</th>
                </tr>
            </thead>
            <tbody>
                <% if (suppliers.length === 0) { %>
                    <tr>
                        <td colspan="4" class="text-center text-gray-400 py-20 text-xl">
                            <i class="fas fa-inbox text-4xl mb-3 block"></i>
                            ยังไม่มีผู้จำหน่ายในระบบ
                        </td>
                    </tr>
                <% } %>

                <!-- ✅ แถวข้อมูลจริง -->
                <% suppliers.forEach((sup) => { %>
                    <tr class="sup-row border-t border-[#2a3a6e]/60 hover:bg-[#1e2b50]/50 transition-colors"
                        data-name="<%= sup.comp_name.toLowerCase() %>">
                        <td class="py-4 px-5">
                            <input type="checkbox" name="selected" value="<%= sup.sup_id %>" class="row-check custom-check" />
                        </td>
                        <td class="py-4 px-4">
                            <span class="text-white text-[16px]"><%= sup.comp_name %></span>
                        </td>
                        <td class="py-4 px-4">
                            <span class="text-white text-[16px]"><%= sup.comp_phone %></span>
                        </td>
                        <td class="py-4 px-4">
                            <div class="flex gap-2">
                                <button onclick="openEditModal(<%= sup.sup_id %>, '<%= sup.comp_name %>', '<%= sup.comp_phone %>')"
                                    class="bg-[#3B82F6] hover:bg-[#2563EB] text-white px-5 py-2 rounded-lg font-medium text-[14px] transition-colors shadow flex items-center gap-2">
                                    <i class="fas fa-pen-to-square text-xs"></i> แก้ไข
                                </button>
                                <button onclick="confirmDelete(<%= sup.sup_id %>, '<%= sup.comp_name %>')"
                                    class="bg-[#EF4444] hover:bg-[#DC2626] text-white px-5 py-2 rounded-lg font-medium text-[14px] transition-colors shadow flex items-center gap-2">
                                    <i class="fas fa-trash text-xs"></i> ลบ
                                </button>
                            </div>
                        </td>
                    </tr>
                <% }) %>

                    <!-- ✅ แถวว่างเติมให้ครบ limit (เห็นช่องตาราง แต่ไม่มีข้อมูล) -->
                    <% for (let i = suppliers.length; i < limit; i++) { %>
                        <tr class="border-t border-[#2a3a6e]/60">
                            <td class="py-4 px-5">&nbsp;</td>
                            <td class="py-4 px-4">&nbsp;</td>
                            <td class="py-4 px-4">&nbsp;</td>
                            <td class="py-4 px-4">&nbsp;</td>
                        </tr>
                    <% } %>
            </tbody>
        </table>
        
        <!-- ✅ Pagination — mt-6 ให้ห่างจากตาราง -->
        <div class="flex items-center justify-between py-4 text-white text-[14px]" style="width: 1147px;">

            <!-- ซ้าย -->
            <div class="flex items-center gap-3">
                <span class="text-gray-400">จำนวนแถวต่อ 1 หน้า</span>
                <select id="limitSelect" onchange="changeLimit(this.value)"
                        class="bg-[#1a2342] border border-[#4BA3E3]/40 text-white rounded-md
                            pl-2 py-1 text-[14px] focus:outline-none cursor-pointer">
                    <option value="5"  <%= limit===5  ? 'selected':'' %>>5</option>
                    <option value="10" <%= limit===10 ? 'selected':'' %>>10</option>
                    <option value="20" <%= limit===20 ? 'selected':'' %>>20</option>
                    <option value="50" <%= limit===50 ? 'selected':'' %>>50</option>
                </select>
            </div>

            <!-- ขวา -->
            <div class="flex items-center gap-0.5">

                <!-- ◄ ย้อนกลับ -->
                <a href="/supplier_management?page=<%= Math.max(1, currentPage-1) %>&limit=<%= limit %>"
                class="w-8 h-8 flex items-center justify-center
                        <%= currentPage <= 1 ? 'text-slate-600 pointer-events-none' : 'text-gray-400 hover:text-white' %>">
                    <i class="fas fa-chevron-left text-xs"></i>
                </a>

                <!-- ✅ เลขหน้า — แสดงทุกหน้า -->
                <% if (totalPages <= 7) { %>
                    <!-- หน้าไม่เยอะ แสดงหมด -->
                    <% for (let p = 1; p <= totalPages; p++) { %>
                        <a href="/supplier_management?page=<%= p %>&limit=<%= limit %>"
                        class="w-8 h-8 flex items-center justify-center text-[14px] font-medium rounded-md
                                <%= p === currentPage
                                    ? 'border border-[#4BA3E3] text-white bg-[#4BA3E3]/10'
                                    : 'text-gray-400 hover:text-white' %>">
                            <%= p %>
                        </a>
                    <% } %>
                <% } else { %>
                    <!-- หน้าเยอะ แสดง 1 ... 4 [5] 6 ... 10 -->
                    <% if (currentPage > 3) { %>
                        <a href="/supplier_management?page=1&limit=<%= limit %>"
                        class="w-8 h-8 flex items-center justify-center text-[14px] text-gray-400 hover:text-white rounded-md">1</a>
                        <span class="w-8 h-8 flex items-center justify-center text-gray-500">...</span>
                    <% } %>

                    <% 
                        let start = Math.max(1, currentPage - 2);
                        let end = Math.min(totalPages, currentPage + 2);
                        if (currentPage <= 3) end = Math.min(totalPages, 5);
                        if (currentPage >= totalPages - 2) start = Math.max(1, totalPages - 4);
                    %>
                    <% for (let p = start; p <= end; p++) { %>
                        <a href="/supplier_management?page=<%= p %>&limit=<%= limit %>"
                        class="w-8 h-8 flex items-center justify-center text-[14px] font-medium rounded-md
                                <%= p === currentPage
                                    ? 'border border-[#4BA3E3] text-white bg-[#4BA3E3]/10'
                                    : 'text-gray-400 hover:text-white' %>">
                            <%= p %>
                        </a>
                    <% } %>

                    <% if (currentPage < totalPages - 2) { %>
                        <span class="w-8 h-8 flex items-center justify-center text-gray-500">...</span>
                        <a href="/supplier_management?page=<%= totalPages %>&limit=<%= limit %>"
                        class="w-8 h-8 flex items-center justify-center text-[14px] text-gray-400 hover:text-white rounded-md"><%= totalPages %></a>
                    <% } %>
                <% } %>

                <!-- ► ถัดไป -->
                <a href="/supplier_management?page=<%= Math.min(totalPages, currentPage+1) %>&limit=<%= limit %>"
                class="w-8 h-8 flex items-center justify-center
                        <%= currentPage >= totalPages ? 'text-slate-600 pointer-events-none' : 'text-gray-400 hover:text-white' %>">
                    <i class="fas fa-chevron-right text-xs"></i>
                </a>

                <!-- ►► ไปหน้าสุดท้าย -->
                <a href="/supplier_management?page=<%= totalPages %>&limit=<%= limit %>"
                class="w-8 h-8 flex items-center justify-center
                        <%= currentPage >= totalPages ? 'text-slate-600 pointer-events-none' : 'text-gray-400 hover:text-white' %>">
                    <i class="fas fa-angles-right text-xs"></i>
                </a>
            </div>
        </div>





    </div>




    <div id="add-sup-modal" tabindex="-1" 
        class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50">
        
        <form action="/supplier_management" method="POST"
            class="flex flex-col bg-white rounded-xl shadow-lg w-[500px] h-[466px] p-6">
            
            <!-- Header -->
            <div class="flex justify-between">
                <p class="text-md font-normal text-[#9E9E9E] ml-5 mt-3">แก้ไขข้อมูล</p>
                <button data-modal-hide="add-sup-modal" class="mr-3">
                        <i class="fa-solid fa-xmark text-2xl" style="color: #9E9E9E;"></i>
                </button>
            </div>
            <h1 class="text-[36px] ml-5">เพิ่มผู้จัดจำหน่าย</h1>

            <!-- Body -->
                <div class="flex flex-col w-[80%] ml-8 mt-5">
                    <label for="username" class="text-[16px] text-[#9E9E9E] mt-3">ชื่อบริษัท</label>
                    <input type="text" id="username" name="username" class="bg-[#F5F5F5] border-b-2 border-[#1B3563] h-[40px] outline-0 p-3 w-[100%] text-[#1B3563] mt-1">
                
                    <label for="username" class="text-[16px] text-[#9E9E9E] mt-3">เบอร์โทรติดต่อ</label>
                    <input type="text" id="username" name="username" class="bg-[#F5F5F5] border-b-2 border-[#1B3563] h-[40px] outline-0 p-3 w-[100%] text-[#1B3563] mt-1">
                
                </div>

            <!-- Button -->
            <div class="w-[100%] flex justify-end pt-5 gap-5 mt-auto mb-3 pr-3">
                <button type="submit" class="px-[32px] py-[12px] bg-[#1B3563] rounded-[8px] text-white">
                    ยืนยันการเพิ่ม
                </button>
                <button type="button" data-modal-hide="add-sup-modal" class="px-[32px] py-[12px] bg-[#F00] rounded-[8px] text-white">
                    ยกเลิก
                </button>
            </div>
        </form>
    </div>
    
    

</body>
</html>